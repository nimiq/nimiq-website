485dcb4d-19da-40d2-852f-49fee17cbcfa","https://t.me/Nimiq","telegram","ZuKG4xIAACMAfaDY","oklch(0.6 0.14119 241.5546)","i-nimiq:logos-telegram-mono scale-97",{"link":561,"platform":564,"id":565,"color":566,"icon":567},{"link_type":154,"key":562,"url":563,"target":157},"6f210f81-665b-499d-af6b-56e4846e81e0","https://www.reddit.com/r/Nimiq","reddit","ZuJsYBIAACIAfXmg","oklch(0.66 0.229356 35.4025)","i-nimiq:logos-reddit-mono scale-105",{"link":569,"platform":572,"id":573,"color":574,"icon":575},{"link_type":154,"key":570,"url":571,"target":157},"42312cae-e134-4a3d-a8e9-80cdd6c1d766","https://github.com/nimiq","github","ZuJshBIAACQAfXnX","oklch(0.32 0 0)","i-nimiq:logos-github-mono",{"link":577,"platform":580,"id":581,"color":582,"icon":583},{"link_type":154,"key":578,"url":579,"target":157},"a6a82d20-d325-4ed2-b48e-b554cd424675","https://www.youtube.com/c/nimiq","youtube","ZuJtIhIAACUAfXrF","oklch(0.63 0.2577 29.23)","i-nimiq:logos-youtube-mono scale-85",{"link":585,"platform":588,"id":589,"color":590,"icon":591},{"link_type":154,"key":586,"url":587,"target":157},"3ced9e9d-a341-411d-b749-cafbe03bf8af","https://discord.gg/cMHemg8","discord","ZuJtRxIAACUAfXr8","oklch(0.58 0.2091 273.85)","i-nimiq:logos-discord-mono scale-86",{"link":593,"platform":596,"id":597,"color":598,"icon":599},{"link_type":154,"key":594,"url":595,"target":157},"647b2a05-ab23-488b-a538-f2231f2474fd","https://forum.nimiq.community","nimiqForum","ZuJtbxIAACUAfXs5","oklch(0.79 0.1593 85.61)","i-nimiq:logos-nimiq-forum-mono",{"link":601,"platform":604,"id":605,"color":606,"icon":607},{"link_type":154,"key":602,"url":603,"target":157},"c8b69a25-2903-4cac-b6f5-63f54d15fb47","https://www.facebook.com/nimiq","facebook","ZuJteBIAACMAfXtL","oklch(0.52 0.1259 262.97)","i-nimiq:logos-facebook-mono",{"link":609,"platform":612,"id":613,"color":614,"icon":615},{"link_type":154,"key":610,"url":611,"target":157},"28b52944-decc-4943-8801-1b6d2fc79dda","https://www.instagram.com/wearenimiq","instagram","ZuJtjRIAACQAfXtu","oklch(0.56 0.1907 350.4)","i-nimiq:logos-instagram-mono",{"buttonLabel":617,"slides":618},"Technical Details",[619,636,651,665,678,686],{"richText":620},[621,625,633],{"type":622,"text":623,"spans":624,"direction":34},"heading3","Micro Blocks",[],{"type":626,"url":627,"alt":6,"copyright":6,"dimensions":628,"id":631,"edit":632},"image","https://images.prismic.io/nimiq/ZvvnQbVsGrYSwN8L_micro-block.webp?auto=format,compress",{"width":629,"height":630},648,652,"ZvvnQbVsGrYSwN8L",{"x":41,"y":41,"zoom":165,"background":151},{"type":37,"text":634,"spans":635,"direction":34},"Micro Blocks contain transactions. Creating and sharing the block can take less than one second, thus transactions are confirmed quickly.",[],{"richText":637},[638,641,648],{"type":622,"text":639,"spans":640,"direction":34},"Skip Blocks",[],{"type":626,"url":642,"alt":6,"copyright":6,"dimensions":643,"id":646,"edit":647},"https://images.prismic.io/nimiq/ZvvoFLVsGrYSwN87_skip-block.webp?auto=format,compress",{"width":644,"height":645},640,736,"ZvvoFLVsGrYSwN87",{"x":41,"y":41,"zoom":165,"background":151},{"type":37,"text":649,"spans":650,"direction":34},"When the currently active slot fails to produce a Micro Block on time, the other validators in the epoch can vote to produce a Skip Block instead, skipping the current slot. The block is accepted when two thirds of all slots vote for the Skip Block.",[],{"richText":652},[653,656,662],{"type":622,"text":654,"spans":655,"direction":34},"Macro Blocks",[],{"type":626,"url":657,"alt":6,"copyright":6,"dimensions":658,"id":660,"edit":661},"https://images.prismic.io/nimiq/ZvvnQ7VsGrYSwN8O_macro-block.webp?auto=format,compress",{"width":644,"height":659},832,"ZvvnQ7VsGrYSwN8O",{"x":41,"y":41,"zoom":165,"background":151},{"type":37,"text":663,"spans":664,"direction":34},"Macro Blocks mark the beginning and end of batches and epochs. They must be voted for by at least two thirds of all active slots. A Macro Block finalizes all transactions of the current batch. Epoch-finalizing Macro Blocks additionally determine the slots and their validators for the next epoch.",[],{"richText":666},[667,670,675],{"type":622,"text":668,"spans":669,"direction":34},"Batch and Epoch",[],{"type":626,"url":671,"alt":6,"copyright":6,"dimensions":672,"id":673,"edit":674},"https://images.prismic.io/nimiq/ZvvnQrVsGrYSwN8M_batch-and-epoch.webp?auto=format,compress",{"width":644,"height":645},"ZvvnQrVsGrYSwN8M",{"x":41,"y":41,"zoom":165,"background":151},{"type":37,"text":676,"spans":677,"direction":34},"A batch is the time between two Macro Blocks. A fixed number of batches make up an epoch. For each epoch, 512 slots are randomly assigned to all potential validators proportionally to each validator’s stake. Parameters such as minimum stake, length of batches and epochs (i.e. number of micro blocks), number of slots, etc. are being tested and thus are subject to change before the Mainnet transition. For each micro block a slot is randomly selected — one after the other — so its validator can validate pending transactions and create the block.",[],{"richText":679},[680,683],{"type":622,"text":681,"spans":682,"direction":34},"Validator",[],{"type":37,"text":684,"spans":685,"direction":34},"Validators are responsible for creating blocks and validating blocks produced by others. They are chosen according to their stake — the higher the stake, the more likely they are chosen. Validators are replaced in fixed intervals, called epochs. If a validator is found to be misbehaving, the validator will be punished. There are various severities of punishment, from taking away their block reward, deactivating the validator, all the way to on-chain jail. Misbehavior includes producing invalid blocks or more than one block at a time (fork blocks). The potential loss of some of their block reward and jail time ensures that validators don’t misbehave.",[],{"richText":687},[688,691],{"type":622,"text":689,"spans":690,"direction":34},"Slot",[],{"type":37,"text":692,"spans":693,"direction":34},"A slot is like a ticket allowing a validator to create a block. The slots for an epoch are assigned to active validators and for each block the active slot is chosen with a Verifiable Random Function (VRF). The active slot allows a validator to create a block. A validator can have multiple slots per epoch, depending on their stake.",[],1752917349657]