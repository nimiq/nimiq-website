86,"id":187,"edit":188},{"width":185,"height":110},65,"https://nimiq.cdn.prismic.io/nimiq/ZvKuh7VsGrYSv1P3_image-1-.svg","ZvKuh7VsGrYSv1P3",{"x":114,"y":114,"zoom":115,"background":189},"transparent",[191],{"type":119,"text":192,"spans":193},"Multi currency",[],[195],{"type":43,"text":196,"spans":197,"direction":40},"Accept Bitcoin, USDC and NIM directly to your wallet.",[],{"backgroundColor":89,"link":199,"linkLabel":6,"bgColor":89,"cta":200},{"link_type":55},{"link_type":55},"grid_section$dd96a9e6-7a91-4ff0-aee6-299425c2d91d","grid_section",{"variation":68,"version":26,"items":204,"primary":206,"id":220,"slice_type":104,"slice_label":6},[205],{},{"bgColor":20,"label":207,"headline":208,"subline":212,"cta":216,"linkHref":217,"linkLabel":6,"icon":218,"iconName":6,"backgroundColor":20,"links":219},"Learn it",[209],{"type":92,"text":210,"spans":211},"What is Cryptopayment.link?",[],[213],{"type":43,"text":214,"spans":215},"“Don’t buy it, earn it.” is the basic concept Nimiq aims to enable with cryptopayment.link. It allows everyone to charge crypto for services and products in seconds.",[],{"link_type":55},{"link_type":55},{},[],"simple_headline$516e1f21-5e00-4449-9e14-08660997dc9b",{"variation":68,"version":26,"items":222,"primary":253,"id":254,"slice_type":255,"slice_label":6},[223,238],{"backgroundColor":89,"content":224,"bgColor":89},[225,228,235],{"type":119,"text":226,"spans":227},"What is it about?",[],{"type":75,"url":229,"alt":6,"copyright":6,"dimensions":230,"id":233,"edit":234},"https://prismic-io.s3.amazonaws.com/nimiq/91319641-44e4-40c1-8471-7051cc077e6d_what-is-it-about.svg",{"width":231,"height":232},472,200,"YlbgFhIAAC4Aabjl",{"x":114,"y":114,"zoom":115,"background":116},{"type":43,"text":236,"spans":237},"It is about earning crypto instead of buying it. By accepting BTC, ETH or NIM for your effort/service, you get a piece of the future and widen your audience. The payment is purely peer-to-peer, that means it goes from the paying persons crypto wallet directly to yours, without a middleman and completely for free.",[],{"backgroundColor":239,"content":240,"bgColor":252},"blue-dark",[241,244,249],{"type":119,"text":242,"spans":243},"Who is it for?",[],{"type":75,"url":245,"alt":6,"copyright":6,"dimensions":246,"id":247,"edit":248},"https://prismic-io.s3.amazonaws.com/nimiq/4ce47827-0b27-4235-b2ad-73bec75b655e_who-is-it-for.svg",{"width":231,"height":232},"YlbgJBIAAC8Aabkm",{"x":114,"y":114,"zoom":115,"background":116},{"type":43,"text":250,"spans":251},"It is for all small business owners and freelancers who are open to accepting crypto payments. Think about diversifying your income directly. Instead of only getting paid in USD, EUR, etc, take a fraction of your income in crypto and hold it. A great alternative to opening an exchange account, transfering USD and trading into crypto.",[],"darkblue",{"backgroundColor":20,"bgColor":20},"rich_text_cards$d89b490c-ddd2-4ca7-94b7-a55295036ae8","rich_text_cards",{"variation":68,"version":26,"items":257,"primary":293,"id":302,"slice_type":303,"slice_label":6},[258,271,282],{"image":259,"label":266,"description":267},{"dimensions":260,"alt":6,"copyright":6,"url":263,"id":264,"edit":265},{"width":261,"height":262},1368,556,"https://images.prismic.io/nimiq/bfd6a086-0c5b-4393-99cd-0ae823533e34_Frame+23144-min.jpg?auto=compress,format","ZPCY1hEAACAANPHW",{"x":114,"y":114,"zoom":115,"background":116},"Step 1",[268],{"type":43,"text":269,"spans":270},"Quickly create a very simple crypto payment request",[],{"image":272,"label":277,"description":278},{"dimensions":273,"alt":6,"copyright":6,"url":274,"id":275,"edit":276},{"width":261,"height":262},"https://images.prismic.io/nimiq/29529290-7f6b-42b3-b389-f6250f5b2791_Frame+23144-1-min.jpg?auto=compress,format","ZPCY1hEAACEANPHT",{"x":114,"y":114,"zoom":115,"background":116},"Step 2",[279],{"type":43,"text":280,"spans":281},"Show the QR code at the point of sale",[],{"image":283,"label":288,"description":289},{"dimensions":284,"alt":