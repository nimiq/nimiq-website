[{"data":1,"prerenderedAt":738},["ShallowReactive",2],{"prismic-blog_post-unlock-unique-promotional-rewards-with-nimiq--asce":3,"$prismic_navigation":124,"$socialMedias":665},{"id":4,"uid":5,"url":6,"type":7,"href":8,"tags":9,"first_publication_date":10,"last_publication_date":11,"slugs":12,"linked_documents":14,"lang":15,"alternate_languages":16,"data":17},"Zlng8hEAACAA7Ejv","unlock-unique-promotional-rewards-with-nimiq--asce","/blog/unlock-unique-promotional-rewards-with-nimiq--asce","blog_page","https://nimiq.cdn.prismic.io/api/v2/documents/search?ref=aR944RAAACUAypKt&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22Zlng8hEAACAA7Ejv%22%29+%5D%5D",[],"2024-05-31T14:38:44+0000","2024-05-31T15:11:38+0000",[13],"unlock-unique-promotional-rewards-with-nimiq--ascendexs-early-staking-campaign-as-we-transition-to-nimiq-proof-of-stake",[],"en-us",[],{"draft":18,"title":19,"subline":25,"publish_date":30,"authors":31,"image":34,"text":45,"body":46,"meta_title":38,"meta_description":38,"meta_keywords":38,"meta_image":123},false,[20],{"type":21,"text":22,"spans":23,"direction":24},"heading1","Unlock Unique Promotional Rewards with Nimiq & AscendEx's Early Staking Campaign as We Transition to Nimiq Proof-of-Stake",[],"ltr",[26],{"type":27,"text":28,"spans":29,"direction":24},"paragraph","Get ready for an incredible opportunity with Nimiq and AscendEx! As we approach the launch of Nimiq Proof-of-Stake (PoS), AscendEx users can earn substantial rewards by staking their NIM early. Enjoy an exceptional one-time 50% APR for the first two weeks of early staking. Discover all the details here.",[],"2024-05-31",[32],{"name":33},"Team Nimiq",{"dimensions":35,"alt":38,"copyright":38,"url":39,"id":40,"edit":41},{"width":36,"height":37},1860,897,null,"https://images.prismic.io/nimiq/Zlng66WtHYXtT-i3_BlogStakeatAscendEX.png?auto=format,compress","Zlng66WtHYXtT-i3",{"x":42,"y":42,"zoom":43,"background":44},0,1,"transparent",[],[47],{"variation":48,"version":49,"items":50,"primary":51,"id":121,"slice_type":122,"slice_label":38},"default","sktwi1xtmkfgx8626",[],{"backgroundColor":52,"richText":53,"centerHeading":18,"bgColor":120},"white",[54,57,60,64,66,69,71,86,88,92,94,103,105,108,110,113,115,118],{"type":27,"text":55,"spans":56,"direction":24},"Nimiq is set to switch from Proof-of-Work (PoW) to Proof-of-Stake, marking a significant upgrade to Nimiq’s native blockchain performance. This switch will enable over 1000 transactions per second with near-instant confirmation times, making Nimiq payments one of the fastest and most efficient in the industry without compromising censorship resistance.",[],{"type":27,"text":58,"spans":59,"direction":24},"",[],{"type":61,"text":62,"spans":63,"direction":24},"heading2","AscendEx Joins the Action ",[],{"type":27,"text":58,"spans":65,"direction":24},[],{"type":27,"text":67,"spans":68,"direction":24},"The Nimiq community is thrilled as we prepare for this major transition, and we have exciting news for AscendEx users. AscendEx will support NIM staking from the day of the migration to Proof-of-Stake, offering users a seamless staking experience. What's more, you can start earning rewards even before the migration happens!",[],{"type":27,"text":58,"spans":70,"direction":24},[],{"type":27,"text":72,"spans":73,"direction":24},"High Rewards with Early Staking: As part of this groundbreaking upgrade, AscendEx is offering an exceptional early staking opportunity. Users will enjoy an impressive 50% APR for the first two weeks, followed by a 16% APR until the actual transition to Proof-of-Stake and its naturally resulting APR. This is your chance to maximize your rewards while being part of Nimiq's next big step forward. Learn more about Nimiq Early Staking on AscendEX here.",[74,77,85],{"start":42,"end":75,"type":76},33,"strong",{"start":78,"end":79,"type":80,"data":81},397,450,"hyperlink",{"link_type":82,"url":83,"target":84},"Web","https://ascendex.com/en/support/articles/98790","_self",{"start":78,"end":79,"type":76},{"type":27,"text":58,"spans":87,"direction":24},[],{"type":89,"text":90,"spans":91,"direction":24},"heading3","More Excitement to Come ",[],{"type":27,"text":58,"spans":93,"direction":24},[],{"type":27,"text":95,"spans":96,"direction":24},"Alongside early staking, we’re launching additional activities to make this transition even more exciting. These initiatives aim to engage and grow our community and enhance your experience as we move towards a Nimiq blockchain at the cutting edge of consensus technology. Stay tuned for more!",[97,102],{"start":98,"end":99,"type":80,"data":100},273,293,{"link_type":82,"url":101,"target":84},"https://x.com/nimiq",{"start":98,"end":99,"type":76},{"type":27,"text":58,"spans":104,"direction":24},[],{"type":89,"text":106,"spans":107,"direction":24},"The Countdown is On! ",[],{"type":27,"text":58,"spans":109,"direction":24},[],{"type":27,"text":111,"spans":112,"direction":24},"Prepare your NIM for an enhanced staking experience with Nimiq Proof-of-Stake on AscendEx. Now is the perfect time to get involved, take advantage of high early rewards, and participate in exciting community events.",[],{"type":27,"text":58,"spans":114,"direction":24},[],{"type":27,"text":116,"spans":117,"direction":24},"Pura Vida",[],{"type":27,"text":33,"spans":119,"direction":24},[],"grey","rich_text$351ca1e2-0877-4177-a1a9-358783ea1e0c","rich_text",{},{"appsGroupName":125,"appsLinks":126,"howToTitle":284,"appsAdditionalFooterLinks":285,"howToLinks":286,"techGroupName":299,"techLinks":300,"githubLinkLabel":350,"techAdditionalFooterLinks":351,"techItems":352,"communityGroupName":367,"communityLinks":368,"communityItems":401,"communityAdditionalFooterLinks":411,"projectGroupName":414,"projectLinks":415,"projectAdditionalFooterLinks":459,"projectItems":460,"getStartedGroupName":473,"getStartedLinks":474,"newToCryptoTitle":38,"newToCryptoLinks":497,"getStartedAdditionalFooterLinks":498,"andMoreGroupName":499,"andMoreLinks":500,"legalPages":516,"extraHeaderLinks":517,"newslett