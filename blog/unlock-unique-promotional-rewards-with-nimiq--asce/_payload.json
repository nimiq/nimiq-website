[{"data":1,"prerenderedAt":657},["ShallowReactive",2],{"prismic-post-unlock-unique-promotional-rewards-with-nimiq--asce":3,"$prismic_navigation":123,"$socialMedias":584},{"id":4,"uid":5,"url":6,"type":7,"href":8,"tags":9,"first_publication_date":10,"last_publication_date":11,"slugs":12,"linked_documents":14,"lang":15,"alternate_languages":16,"data":17},"Zlng8hEAACAA7Ejv","unlock-unique-promotional-rewards-with-nimiq--asce",null,"blog_page","https://nimiq.cdn.prismic.io/api/v2/documents/search?ref=aIdnnxAAACcA_UJ9&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22Zlng8hEAACAA7Ejv%22%29+%5D%5D",[],"2024-05-31T14:38:44+0000","2024-05-31T15:11:38+0000",[13],"unlock-unique-promotional-rewards-with-nimiq--ascendexs-early-staking-campaign-as-we-transition-to-nimiq-proof-of-stake",[],"en-us",[],{"draft":18,"title":19,"subline":25,"publish_date":30,"authors":31,"image":34,"text":44,"body":45,"meta_title":6,"meta_description":6,"meta_keywords":6,"meta_image":122},false,[20],{"type":21,"text":22,"spans":23,"direction":24},"heading1","Unlock Unique Promotional Rewards with Nimiq & AscendEx's Early Staking Campaign as We Transition to Nimiq Proof-of-Stake",[],"ltr",[26],{"type":27,"text":28,"spans":29,"direction":24},"paragraph","Get ready for an incredible opportunity with Nimiq and AscendEx! As we approach the launch of Nimiq Proof-of-Stake (PoS), AscendEx users can earn substantial rewards by staking their NIM early. Enjoy an exceptional one-time 50% APR for the first two weeks of early staking. Discover all the details here.",[],"2024-05-31",[32],{"name":33},"Team Nimiq",{"dimensions":35,"alt":6,"copyright":6,"url":38,"id":39,"edit":40},{"width":36,"height":37},1860,897,"https://images.prismic.io/nimiq/Zlng66WtHYXtT-i3_BlogStakeatAscendEX.png?auto=format,compress","Zlng66WtHYXtT-i3",{"x":41,"y":41,"zoom":42,"background":43},0,1,"transparent",[],[46],{"variation":47,"version":48,"items":49,"primary":50,"id":120,"slice_type":121,"slice_label":6},"default","sktwi1xtmkfgx8626",[],{"backgroundColor":51,"richText":52,"centerHeading":18,"bgColor":119},"white",[53,56,59,63,65,68,70,85,87,91,93,102,104,107,109,112,114,117],{"type":27,"text":54,"spans":55,"direction":24},"Nimiq is set to switch from Proof-of-Work (PoW) to Proof-of-Stake, marking a significant upgrade to Nimiq’s native blockchain performance. This switch will enable over 1000 transactions per second with near-instant confirmation times, making Nimiq payments one of the fastest and most efficient in the industry without compromising censorship resistance.",[],{"type":27,"text":57,"spans":58,"direction":24},"",[],{"type":60,"text":61,"spans":62,"direction":24},"heading2","AscendEx Joins the Action ",[],{"type":27,"text":57,"spans":64,"direction":24},[],{"type":27,"text":66,"spans":67,"direction":24},"The Nimiq community is thrilled as we prepare for this major transition, and we have exciting news for AscendEx users. AscendEx will support NIM staking from the day of the migration to Proof-of-Stake, offering users a seamless staking experience. What's more, you can start earning rewards even before the migration happens!",[],{"type":27,"text":57,"spans":69,"direction":24},[],{"type":27,"text":71,"spans":72,"direction":24},"High Rewards with Early Staking: As part of this groundbreaking upgrade, AscendEx is offering an exceptional early staking opportunity. Users will enjoy an impressive 50% APR for the first two weeks, followed by a 16% APR until the actual transition to Proof-of-Stake and its naturally resulting APR. This is your chance to maximize your rewards while being part of Nimiq's next big step forward. Learn more about Nimiq Early Staking on AscendEX here.",[73,76,84],{"start":41,"end":74,"type":75},33,"strong",{"start":77,"end":78,"type":79,"data":80},397,450,"hyperlink",{"link_type":81,"url":82,"target":83},"Web","https://ascendex.com/en/support/articles/98790","_self",{"start":77,"end":78,"type":75},{"type":27,"text":57,"spans":86,"direction":24},[],{"type":88,"text":89,"spans":90,"direction":24},"heading3","More Excitement to Come ",[],{"type":27,"text":57,"spans":92,"direction":24},[],{"type":27,"text":94,"spans":95,"direction":24},"Alongside early staking, we’re launching additional activities to make this transition even more exciting. These initiatives aim to engage and grow our community and enhance your experience as we move towards a Nimiq blockchain at the cutting edge of consensus technology. Stay tuned for more!",[96,101],{"start":97,"end":98,"type":79,"data":99},273,293,{"link_type":81,"url":100,"target":83},"https://x.com/nimiq",{"start":97,"end":98,"type":75},{"type":27,"text":57,"spans":103,"direction":24},[],{"type":88,"text":105,"spans":106,"direction":24},"The Countdown is On! ",[],{"type":27,"text":57,"spans":108,"direction":24},[],{"type":27,"text":110,"spans":111,"direction":24},"Prepare your NIM for an enhanced staking experience with Nimiq Proof-of-Stake on AscendEx. Now is the perfect time to get involved, take advantage of high early rewards, and participate in exciting community events.",[],{"type":27,"text":57,"spans":113,"direction":24},[],{"type":27,"text":115,"spans":116,"direction":24},"Pura Vida",[],{"type":27,"text":33,"spans":118,"direction":24},[],"grey","rich_text$351ca1e2-0877-4177-a1a9-358783ea1e0c","rich_text",{},{"appsGroupName":124,"appsLinks":125,"howToTitle":248,"howToLinks":249,"appsAdditionalFooterLinks":265,"techGroupName":266,"techLinks":267,"githubLinkLabel":313,"techAdditionalFooterLinks":314,"communityGroupName":315,"communityLinks":316,"communityAdditionalFooterLinks":357,"projectGroupName":358,"projectLinks":359,"projectAdditionalFooterLinks":403,"getStartedGroupName":404,"getStartedLinks":405,"newToCryptoTitle":6,"newToCryptoLinks":423,"getStartedAdditionalFooterLinks":424,"andMoreGroupName":425,"andMoreLinks":426,"legalPages":446,"extraHeaderLinks":447,"newsletterCta":448,"newsletterPlaceholder":449,"socialMediaCta":450,"nimiqShortDescription":451,"hothref":452,"hottext":459,"hotsince":4