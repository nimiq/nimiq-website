[{"data":1,"prerenderedAt":622},["ShallowReactive",2],{"prismic-post-nimiq-x-kucoin-early-staking-campaign-launch":3,"$prismic_navigation":90,"$socialMedias":550},{"id":4,"uid":5,"url":6,"type":7,"href":8,"tags":9,"first_publication_date":10,"last_publication_date":11,"slugs":12,"linked_documents":13,"lang":14,"alternate_languages":15,"data":16},"Zkue-RAAACAAw-SI","nimiq-x-kucoin-early-staking-campaign-launch",null,"blog_page","https://nimiq.cdn.prismic.io/api/v2/documents/search?ref=aIdnnxAAACcA_UJ9&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22Zkue-RAAACAAw-SI%22%29+%5D%5D",[],"2024-05-20T20:06:56+0000","2024-05-23T23:33:25+0000",[5],[],"en-us",[],{"draft":17,"title":18,"subline":24,"publish_date":29,"authors":30,"image":33,"text":43,"body":44,"meta_title":6,"meta_description":6,"meta_keywords":6,"meta_image":89},false,[19],{"type":20,"text":21,"spans":22,"direction":23},"heading1","Nimiq x KuCoin Early Staking Campaign Launch",[],"ltr",[25],{"type":26,"text":27,"spans":28,"direction":23},"paragraph","Exciting times are ahead! With the switch to Nimiq Proof-of-Stake around the corner, KuCoin is offering its users the chance to get in early on the staking experience. Earn rewards by staking your NIM now, and don't miss the new trading competition. Everything you need to know is right here.",[],"2024-05-21",[31],{"name":32},"Team Nimiq",{"dimensions":34,"alt":6,"copyright":6,"url":37,"id":38,"edit":39},{"width":35,"height":36},3720,1793,"https://images.prismic.io/nimiq/ZkudwSol0Zci9TA3_BlogStakeatKucoin.png?auto=format,compress","ZkudwSol0Zci9TA3",{"x":40,"y":40,"zoom":41,"background":42},0,1,"transparent",[],[45],{"variation":46,"version":47,"items":48,"primary":49,"id":87,"slice_type":88,"slice_label":6},"default","sktwi1xtmkfgx8626",[],{"backgroundColor":50,"richText":51,"centerHeading":17,"bgColor":86},"white",[52,55,59,62,65,68,71,74,84],{"type":26,"text":53,"spans":54,"direction":23},"Nimiq is currently running on a Proof-of-Work (PoW) system, but the landscape is set to change dramatically with the migration to Nimiqs own Proof-of-Stake (PoS) consensus mechanism. This major upgrade, the result of four years of research and development, will enable transactions to be processed at speeds of over 1000 transactions per second, with confirmation time of around one second, increasing performance and enhancing user experience significantly, all the while maintaining decentralization and censorship resistance of the network, and running nodes in the browser.",[],{"type":56,"text":57,"spans":58,"direction":23},"heading3","KuCoin Joins the Celebration",[],{"type":26,"text":60,"spans":61,"direction":23},"As Nimiq plans to make this big switch, KuCoin is here to make sure you are part of it from the start. We are excited to have KuCoin join the Nimiq Proof-of-Stake migration as a launch partner and support this change by allowing Nimiq users to participate in staking early. KuCoin users will not only have the opportunity to stake on the day of the launch but can also earn pre-launch rewards through the special early staking offer. It’s a perfect chance to earn rewards while helping to pilot the new system.",[],{"type":56,"text":63,"spans":64,"direction":23},"Get Ready for More Action ",[],{"type":26,"text":66,"spans":67,"direction":23},"The excitement doesn’t end with early staking. Alongside early staking, we're hosting a ‘Predict & Earn’ contest and we've got even more surprises! These are fantastic ways to get more involved, have some fun, and make your journey into the new Nimiq ecosystem as exciting as possible.",[],{"type":56,"text":69,"spans":70,"direction":23},"Ready, Set, Stake!",[],{"type":26,"text":72,"spans":73,"direction":23},"The countdown is on! Gear up your NIM for an enhanced staking experience on KuCoin with the new Proof-of-Stake system. Now's the perfect time to dive in, earn early rewards, and enjoy the buzz of competition. ",[],{"type":26,"text":75,"spans":76,"direction":23},"Stay tuned to get all the news. Let's make the most of this upgrade together! ",[77],{"start":40,"end":78,"type":79,"data":80},10,"hyperlink",{"link_type":81,"url":82,"target":83},"Web","https://twitter.com/nimiq","_blank",{"type":26,"text":32,"spans":85,"direction":23},[],"grey","rich_text$5618634f-1a91-4d5e-a77f-d2208a30a552","rich_text",{},{"appsGroupName":91,"appsLinks":92,"howToTitle":214,"howToLinks":215,"appsAdditionalFooterLinks":231,"techGroupName":232,"techLinks":233,"githubLinkLabel":279,"techAdditionalFooterLinks":280,"communityGroupName":281,"communityLinks":282,"communityAdditionalFooterLinks":323,"projectGroupName":324,"projectLinks":325,"projectAdditionalFooterLinks":369,"getStartedGroupName":370,"getStartedLinks":371,"newToCryptoTitle":6,"newToCryptoLinks":389,"getStartedAdditionalFooterLinks":390,"andMoreGroupName":391,"andMoreLinks":392,"legalPages":412,"extraHeaderLinks":413,"newsletterCta":414,"newsletterPlaceholder":415,"socialMediaCta":416,"nimiqShortDescription":417,"hothref":418,"hottext":425,"hotsince":426,"hotuntil":6,"announcementBannerHeadline":427,"announcementBannerCtaLabel":428,"announcementBannerCtaLink":429,"announcementBannerShow":17,"blocks":432,"copyrightNotice":549},"Apps",[93,121,148,168,190],{"logo":94,"visual":103,"label":112,"href":113},{"dimensions":95,"alt":97,"copyright":6,"url":98,"id":99,"edit":100},{"width":96,"height":96},48,"Nimiq Logo","https://nimiq.cdn.prismic.io/nimiq/0dbc2a74-5cfb-4b19-a734-611379f6a591_nimiq-product-icon.svg","YlWuhRIAAC0AZFYp",{"x":40,"y":40,"zoom":101,"background":102},2,"#fff",{"dimensions":104,"alt":107,"copyright":6,"url":108,"id":109,"edit":110},{"width":105,"height":106},594,384,"Screenshot of the Nimiq Wallet","https://images.prismic.io/nimiq/18669675-be09-47fd-99bf-5c6eb8e091c0_header-wallet-hero.jpg?auto=compress,format&rect=0,0,817,528&w=594&h=384","ZPXRPBEAACEAS93s",{"x":40,"y":40,"zoom":111,"background":102},0.7272727272727273,"Wallet",{"id":114,"type":115,"tags":116,"lang":6,"slug":117,"first_publication_date":6,"last_p