":232,"key":302,"isBroken":234},"ZcMt9xEAACMA8Hq2",[],"nimiq-pay","2024-04-16T11:49:05+0000","2025-04-21T14:07:40+0000","c4741973-294e-44ce-9ff4-b22f44b79225",{"logo":304,"visual":310,"label":318,"href":319},{"dimensions":305,"alt":306,"copyright":6,"url":307,"id":308,"edit":309},{"width":126,"height":126},"apps logo","https://nimiq.cdn.prismic.io/nimiq/143e1bdb-2568-4cce-b783-adf37cd55095_all-apps-product-icon.svg","YlWumhIAACkAZFaL",{"x":38,"y":38,"zoom":213,"background":40},{"dimensions":311,"alt":312,"copyright":6,"url":313,"id":314,"edit":315},{"width":216,"height":217},"visual for the different apps","https://nimiq.cdn.prismic.io/nimiq/4f3d7984-b2a3-4a8b-809d-20f44a8d428b_header-all-apps.svg","Ylhd3hIAACsAcGuu",{"x":316,"y":38,"zoom":317,"background":40},-52,1.5118110236220472,"All apps",{"id":320,"type":226,"tags":321,"lang":14,"slug":322,"first_publication_date":323,"last_publication_date":324,"uid":325,"link_type":232,"key":326,"isBroken":234},"YjD3dhIAACsAGQke",[],"nimiq-apps","2022-03-15T20:39:16+0000","2025-04-22T10:22:42+0000","apps","269d9d2f-35ce-488c-9932-8efa68c6eee3","How to",[329,334,339],{"href":330,"label":333},{"link_type":50,"key":331,"url":332},"12a0711d-2826-42c9-bc60-2ad7a66a2451","https://youtu.be/fmUkONJu4Ds","Set up wallet",{"href":335,"label":338},{"link_type":50,"key":336,"url":337},"9434a4f5-ab7a-4942-9daa-ce9eb9d2e0e0","https://youtu.be/5X69gLzvdx8","Connect ledger",{"href":340,"label":343},{"link_type":50,"key":341,"url":342},"ddf1290f-ce77-42ec-a05c-71a5a65d1e49","https://youtu.be/CI1_Hyyfk70","Buy NIM",[],"Tech",[347,357,362,372,382],{"href":348,"label":356},{"id":349,"type":226,"tags":350,"lang":14,"slug":351,"first_publication_date":352,"last_publication_date":353,"uid":354,"link_type":232,"key":355,"isBroken":234},"YjOZtRIAACwAJPON",[],"nimiq-in-a-nutshell","2022-03-17T20:27:39+0000","2025-04-22T14:46:02+0000","onepager","0859ccdd-eecd-43a4-90b6-c301f9163e7e","Onepager",{"href":358,"label":361},{"link_type":50,"key":359,"url":3