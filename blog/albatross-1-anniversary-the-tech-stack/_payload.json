o",{"appsGroupName":400,"appsLinks":401,"howToTitle":555,"appsAdditionalFooterLinks":556,"howToLinks":557,"techGroupName":570,"techLinks":571,"githubLinkLabel":621,"techAdditionalFooterLinks":622,"techItems":623,"communityGroupName":638,"communityLinks":639,"communityItems":672,"communityAdditionalFooterLinks":682,"projectGroupName":685,"projectLinks":686,"projectAdditionalFooterLinks":730,"projectItems":731,"getStartedGroupName":744,"getStartedLinks":745,"newToCryptoTitle":39,"newToCryptoLinks":768,"getStartedAdditionalFooterLinks":769,"andMoreGroupName":770,"andMoreLinks":771,"legalPages":787,"extraHeaderLinks":788,"newsletterCta":789,"newsletterPlaceholder":790,"socialMediaCta":791,"nimiqShortDescription":792,"hothref":793,"hottext":801,"hotsince":802,"hotuntil":39,"announcementBannerHeadline":803,"announcementBannerCtaLabel":804,"announcementBannerCtaLink":805,"announcementBannerShow":18,"blocks":808,"copyrightNotice":935},"Apps",[402,434,452,482,504,529],{"logo":403,"visual":411,"label":420,"href":421,"link":432},{"dimensions":404,"alt":406,"copyright":39,"url":407,"id":408,"edit":409},{"width":405,"height":405},48,"Nimiq Logo","https://nimiq.cdn.prismic.io/nimiq/0dbc2a74-5cfb-4b19-a734-611379f6a591_nimiq-product-icon.svg","YlWuhRIAAC0AZFYp",{"x":43,"y":43,"zoom":153,"background":410},"#fff",{"dimensions":412,"alt":415,"copyright":39,"url":416,"id":417,"edit":418},{"width":413,"height":414},594,384,"Screenshot of the Nimiq Wallet","https://images.prismic.io/nimiq/18669675-be09-47fd-99bf-5c6eb8e091c0_header-wallet-hero.jpg?auto=compress,format&rect=0,0,817,528&w=594&h=384","ZPXRPBEAACEAS93s",{"x":43,"y":43,"zoom":419,"background":410},0.7272727272727273,"Wallet",{"id":422,"type":423,"tags":424,"lang":15,"slug":425,"first_publication_date":426,"last_publication_date":427,"uid":428,"url":429,"link_type":430,"key":431,"isBroken":18},"ZyJfmBAAACMAxfzG","page",[],"dont-sleep-on-crypto.create-a-wallet-in-seconds.","2024-10-30T16:32:27+0000","2025-10-21T08:21:19+0000",