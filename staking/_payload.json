[{"data":1,"prerenderedAt":939},["ShallowReactive",2],{"prismic-page-staking":3,"$prismic_navigation":331,"$socialMedias":863,"staking_values":936},{"id":4,"uid":5,"url":6,"type":7,"href":8,"tags":9,"first_publication_date":10,"last_publication_date":11,"slugs":12,"linked_documents":14,"lang":15,"alternate_languages":16,"data":17},"ZzM2ihAAACMAh138","staking","/staking","page","https://nimiq.cdn.prismic.io/api/v2/documents/search?ref=aR944RAAACUAypKt&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22ZzM2ihAAACMAh138%22%29+%5D%5D",[],"2024-11-12T12:40:47+0000","2025-08-26T10:31:54+0000",[13],"stake-nim-and-get--interestperannum--annually",[],"en-us",[],{"draft":18,"headerBackgroundColor":19,"footerBackgroundColor":19,"show_table_of_contents":20,"show_disclaimer":18,"darkHeader":18,"parents":21,"slices":22,"meta_title":328,"meta_description":329,"meta_keywords":42,"meta_image":330},false,"white","None",[],[23,43,62,81,112,129,149,166,197,214,219,242,308],{"variation":5,"version":24,"items":25,"primary":26,"id":40,"slice_type":41,"slice_label":42},"sktwi1xtmkfgx8626",[],{"headline":27,"cta":33,"links":39},[28],{"type":29,"text":30,"spans":31,"direction":32},"heading1","Stake NIM and get {{ interestPerAnnum }} annually ",[],"ltr",{"link_type":34,"key":35,"url":36,"target":37,"text":38},"Web","11dfca11-af31-4672-b405-bb0d05e32aca","https://wallet.nimiq.com","_blank","Start staking",[],"hero_section$362ef66f-736c-4369-b46c-da08f3317cba","hero_section",null,{"variation":44,"version":45,"items":46,"primary":47,"id":60,"slice_type":61,"slice_label":42},"default","initial",[],{"quote":48,"cta":57},[49],{"type":50,"text":51,"spans":52,"direction":32},"paragraph","‘Staking’ means locking up NIM to help secure the network. Get new NIM as a reward. Unstake your NIM at any time.",[53],{"start":54,"end":55,"type":56},1,8,"strong",{"link_type":58,"key":59},"Any","57bd6f89-97d5-4a12-ab61-ef7deb35571e","quote$dc2a470b-78e8-4ca7-a383-6ed3e7317d74","quote",{"variation":44,"version":24,"items":63,"primary":64,"id":79,"slice_type":80,"slice_label":42},[],{"bgColor":65,"label":42,"headline":66,"subline":71,"cta":75,"linkHref":76,"linkLabel":42,"icon":77,"iconName":42,"backgroundColor":65,"links":78},"grey",[67],{"type":68,"text":69,"spans":70,"direction":32},"heading2","Check your potential staking rewards",[],[72],{"type":50,"text":73,"spans":74,"direction":32},"Play around with the staking calculator and find out how much NIM you could earn.",[],{"link_type":58},{"link_type":58},{},[],"simple_headline$589a173c-5899-471c-b54d-bbbf807b3277","simple_headline",{"variation":44,"version":45,"items":82,"primary":83,"id":110,"slice_type":111,"slice_label":42},[],{"title":84,"stakingAmountLabel":85,"initialStakingAmount":86,"stakedSupplyLabel":87,"stakedSupplyInfo":88,"stakingPeriodLabel":98,"stakingPeriodInfo":99,"autoRestakeLabel":103,"stakingRewardsLabel":104,"autoRestakeInfo":105,"note":109},"Staking calculator","Staking amount",1000000,"Staked supply",[89,92,95],{"type":50,"text":90,"spans":91,"direction":32},"This shows the percentage of all coins currently staked compared to the total supply.",[],{"type":50,"text":93,"spans":94,"direction":32},"A low stake is around 25%, a medium stake is 50% and a high stake is 75%.",[],{"type":50,"text":96,"spans":97,"direction":32},"The actual stake ratio isn't fixed, as it depends on how many NIM owners choose to stake. If fewer people stake, your share of the global reward will increase.",[],"Staking period",[100],{"type":50,"text":101,"spans":102,"direction":32},"The staking period determines how long your funds are locked in. A longer period will generally result in a greater return on your investment.",[],"Auto restake","Staking rewards",[106],{"type":50,"text":107,"spans":108,"direction":32},"Stake pools allow you to automatically reinvest the rewards you earn, which can increase your total rewards over time through compounding.",[],"* depends on the current total staking","staking_calculator$654139b2-bec1-4faf-9db2-a91b9d37a635","staking_calculator",{"variation":44,"version":24,"items":113,"primary":114,"id":128,"slice_type":80,"slice_label":42},[],{"bgColor":19,"label":115,"headline":116,"subline":120,"cta":124,"linkHref":125,"linkLabel":42,"icon":126,"iconName":42,"backgroundColor":65,"links":127},"Staking Distribution",[117],{"type":68,"text":118,"spans":119,"direction":32},"Active and decentralized staking",[],[121],{"type":50,"text":122,"spans":123,"direction":32},"A healthy network has a high staked supply, evenly distributed among the various pools and validators.",[],{"link_type":58},{"link_type":58},{},[],"simple_headline$9cd3aec6-7a00-4e58-9167-454c4830d69f",{"variation":44,"version":45,"items":130,"primary":131,"id":147,"slice_type":148,"slice_label":42},[],{"marketCapDistributionInfo":132,"stakedDistributionInfo":140},[133,137],{"type":134,"text":135,"spans":136,"direction":32},"heading3","How much is staked",[],{"type":50,"text":138,"spans":139,"direction":32},"A high staked supply means a safer network but smaller rewards.",[],[141,144],{"type":134,"text":142,"spans":143,"direction":32},"How the stakes are distributed",[],{"type":50,"text":145,"spans":146,"direction":32},"The more evenly stakes are distributed, the stronger the decentralization.",[],"staking_distribution$8fc11326-323b-4e22-b151-2f82ef24cefe","staking_distribution",{"variation":44,"version":24,"items":150,"primary":151,"id":165,"slice_type":80,"slice_label":42},[],{"bgColor":19,"label":152,"headline":153,"subline":157,"cta":161,"linkHref":162,"linkLabel":42,"icon":163,"iconName":42,"backgroundColor":65,"links":164},"Staking in the wallet",[154],{"type":68,"text":155,"spans":156,"direction":32},"So easy, everyone can do it!",[],[158],{"type":50,"text":159,"spans":160,"direction":32},"No tech skills or staking knowledge needed, stake in just three clicks. All it takes is a Nimiq Wallet and as little as 1000 NIM.",[],{"link_type":58},{"link_type":58},{},[],"simple_headline$981456e5-d680-4205-8ad1-5d0e8ee5159f",{"variation":44,"version":45,"items":167,"primary":168,"id":195,"slice_type":196,"slice_label":42},[],{"title":169,"subline":170,"backgroundImage":171,"poster":180,"video":187},"You stay in control","When staking, you ‘delegate’ your NIM \u2028to a pool but they remain in your wallet. \u2028Unstake them at any time.",{"dimensions":172,"alt":42,"copyright":42,"url":175,"id":176,"edit":177},{"width":173,"height":174},1800,838,"https://images.prismic.io/nimiq/ZzpTPq8jQArT08s8_wallet-black-white.webp?auto=format,compress","ZzpTPq8jQArT08s8",{"x":178,"y":178,"zoom":54,"background":179},0,"transparent",{"dimensions":181,"alt":42,"copyright":42,"url":184,"id":185,"edit":186},{"width":182,"height":183},840,1128,"https://images.prismic.io/nimiq/ZzpazK8jQArT08uI_Frame48104392.webp?auto=format,compress","ZzpazK8jQArT08uI",{"x":178,"y":178,"zoom":54,"background":179},{"link_type":188,"key":189,"kind":190,"id":191,"url":192,"name":193,"size":194},"Media","a4ce2f6f-7fa6-4861-afa5-2785a7988f67","file","Z21BuJbqstJ981da","https://nimiq.cdn.prismic.io/nimiq/Z21BuJbqstJ981da_ScreenRecording2024-12-26174136.mp4","Staking-in-nimiq.mp4","22365393","vertical_video$95eee2d0-864a-46ff-a53e-1e91059a8c91","vertical_video",{"variation":44,"version":24,"items":198,"primary":199,"id":213,"slice_type":80,"slice_label":42},[],{"bgColor":19,"label":200,"headline":201,"subline":205,"cta":209,"linkHref":210,"linkLabel":42,"icon":211,"iconName":42,"backgroundColor":19,"links":212},"Validator pools",[202],{"type":68,"text":203,"spans":204,"direction":32},"Let others do the work",[],[206],{"type":50,"text":207,"spans":208,"direction":32},"Not a techy? Stake with a validator. They take care of all the work, earning a small fee. You are always in control of your NIM.",[],{"link_type":58},{"link_type":58},{},[],"simple_headline$b1321aaf-bb4e-4606-bc1a-4763a6ef1ff8",{"variation":44,"version":45,"items":215,"primary":216,"id":217,"slice_type":218,"slice_label":42},[],{},"validator_list$200af2a5-d362-4b96-a98a-6f33e077dd7e","validator_list",{"variation":5,"version":24,"items":220,"primary":221,"id":240,"slice_type":241,"slice_label":42},[],{"headline":222,"cta":226,"requirements":230},[223],{"type":68,"text":224,"spans":225,"direction":32},"Want to run a validator yourself? Check out the docs.",[],{"link_type":34,"key":227,"url":228,"target":37,"text":229},"e8e9bb1e-e9f1-4059-92fe-ed44cf737b74","https://www.nimiq.com/developers/build/set-up-your-own-node/becoming-a-validator","Become a validator",[231,234,237],{"icon":232,"description":233},"i-nimiq:code","Solid tech knowledge required",{"icon":235,"description":236},"i-nimiq:document-filled bottom--2","Comprehensive docs and guides",{"icon":238,"description":239},"i-nimiq:globe-filled","Active and helpful community","banner_slice$8ba2a381-362c-4494-b9f3-ae8fb69d3101","banner_slice",{"variation":44,"version":45,"items":243,"primary":244,"id":306,"slice_type":307,"slice_label":42},[],{"title":245,"questions":246,"cta":301,"moreInsightfulLabel":305},"What you nEed to know",[247,256,265,274,283,292],{"question":248,"answer":252},[249],{"type":134,"text":250,"spans":251,"direction":32},"What is Staking?",[],[253],{"type":50,"text":254,"spans":255,"direction":32},"Staking is the process of delegating tokens to a validator. The validator then uses these tokens to validate transactions and produce blocks on your behalf.",[],{"question":257,"answer":261},[258],{"type":134,"text":259,"spans":260,"direction":32},"What is a validator?",[],[262],{"type":50,"text":263,"spans":264,"direction":32},"A validator is the block producer of Proof-of-Stake blockchains, like a miner in Proof-of-Work blockchains. Validators produce blocks according to a consensus algorithm. ",[],{"question":266,"answer":270},[267],{"type":134,"text":268,"spans":269,"direction":32},"What is a staking pool?",[],[271],{"type":50,"text":272,"spans":273,"direction":32},"While a validator is an individual entity, a staking pool combines the tokens of multiple participants into a single large entity, increasing their collective stake and chances of winning rewards.",[],{"question":275,"answer":279},[276],{"type":134,"text":277,"spans":278,"direction":32},"How does staking help the Nimiq network?",[],[280],{"type":50,"text":281,"spans":282,"direction":32},"Staking helps keep the Nimiq network secure and decentralized. The more NIM is staked and distributed evenly across validators, the stronger and healthier the network becomes, ensuring its reliability.",[],{"question":284,"answer":288},[285],{"type":134,"text":286,"spans":287,"direction":32},"What happens if I don’t stake?",[],[289],{"type":50,"text":290,"spans":291,"direction":32},"You can choose not to stake and not earn any rewards. By not staking, you miss the opportunity to help maintain the network secure and decentralized.",[],{"question":293,"answer":297},[294],{"type":134,"text":295,"spans":296,"direction":32},"How long does it take to have my funds available after I un-stake?",[],[298],{"type":50,"text":299,"spans":300,"direction":32},"Once you un-stake your funds, it usually takes between 12 hours to 4 days for them to become available. The exact time frame depends on your validator's status. In rare cases, validators can be \"jailed\" for up to 4 days, which may delay access to your funds.",[],{"link_type":34,"key":302,"url":303,"target":37,"text":304},"5ba9f7b3-0427-4c4f-bbf4-ba6657935829","https://forum.nimiq.community/","Nimiq forum","Get more insightful answers at the Nimiq forum.","staking_faq$cb136088-daf3-4a69-bd3d-ad99e6e285e1","staking_faq",{"variation":44,"version":24,"items":309,"primary":310,"id":327,"slice_type":80,"slice_label":42},[],{"bgColor":65,"label":42,"headline":311,"subline":315,"cta":321,"linkHref":324,"linkLabel":42,"icon":325,"iconName":42,"backgroundColor":65,"links":326},[312],{"type":68,"text":313,"spans":314,"direction":32},"Stake in the Nimiq wallet and get {{ interestPerAnnum }} annually",[],[316],{"type":50,"text":317,"spans":318,"direction":32},"‘Staking’ means locking up your NIM which helps secure the network. You get new NIM as a reward.",[319],{"start":178,"end":320,"type":56},9,{"link_type":34,"key":322,"url":36,"target":37,"text":323},"54b9a1b1-51f3-4ef4-96e6-bd04fc58d06e","Create a wallet",{"link_type":58},{},[],"simple_headline$893d8f06-18ce-4f5d-8b7c-b906f570be91","Stake NIM and earn rewards","Start staking with Nimiq and earn rewards",{},{"appsGroupName":332,"appsLinks":333,"howToTitle":488,"appsAdditionalFooterLinks":489,"howToLinks":490,"techGroupName":503,"techLinks":504,"githubLinkLabel":554,"techAdditionalFooterLinks":555,"techItems":556,"communityGroupName":571,"communityLinks":572,"communityItems":605,"communityAdditionalFooterLinks":615,"projectGroupName":618,"projectLinks":619,"projectAdditionalFooterLinks":657,"projectItems":658,"getStartedGroupName":671,"getStartedLinks":672,"newToCryptoTitle":42,"newToCryptoLinks":694,"getStartedAdditionalFooterLinks":695,"andMoreGroupName":696,"andMoreLinks":697,"legalPages":713,"extraHeaderLinks":714,"newsletterCta":715,"newsletterPlaceholder":716,"socialMediaCta":717,"nimiqShortDescription":718,"hothref":719,"hottext":728,"hotsince":729,"hotuntil":42,"announcementBannerHeadline":730,"announcementBannerCtaLabel":731,"announcementBannerCtaLink":732,"announcementBannerShow":18,"blocks":735,"copyrightNotice":862},"Apps",[334,365,384,414,436,462],{"logo":335,"visual":344,"label":353,"href":354,"link":364},{"dimensions":336,"alt":338,"copyright":42,"url":339,"id":340,"edit":341},{"width":337,"height":337},48,"Nimiq Logo","https://nimiq.cdn.prismic.io/nimiq/0dbc2a74-5cfb-4b19-a734-611379f6a591_nimiq-product-icon.svg","YlWuhRIAAC0AZFYp",{"x":178,"y":178,"zoom":342,"background":343},2,"#fff",{"dimensions":345,"alt":348,"copyright":42,"url":349,"id":350,"edit":351},{"width":346,"height":347},594,384,"Screenshot of the Nimiq Wallet","https://images.prismic.io/nimiq/18669675-be09-47fd-99bf-5c6eb8e091c0_header-wallet-hero.jpg?auto=compr