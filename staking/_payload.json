[{"data":1,"prerenderedAt":865},["ShallowReactive",2],{"prismic-page-staking":3,"$prismic_navigation":328,"$socialMedias":789,"staking_values":862},{"id":4,"uid":5,"url":6,"type":7,"href":8,"tags":9,"first_publication_date":10,"last_publication_date":11,"slugs":12,"linked_documents":14,"lang":15,"alternate_languages":16,"data":17},"ZzM2ihAAACMAh138","staking",null,"page","https://nimiq.cdn.prismic.io/api/v2/documents/search?ref=aHpGSRAAACYA6jCM&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22ZzM2ihAAACMAh138%22%29+%5D%5D",[],"2024-11-12T12:40:47+0000","2025-07-18T09:46:54+0000",[13],"stake-nim-and-get--interestperannum--annually",[],"en-us",[],{"draft":18,"headerBackgroundColor":19,"footerBackgroundColor":19,"show_table_of_contents":20,"show_disclaimer":18,"darkHeader":18,"parents":21,"slices":22,"meta_title":6,"meta_description":6,"meta_keywords":6,"meta_image":327},false,"white","None",[],[23,42,61,80,111,128,148,165,196,213,218,241,307],{"variation":5,"version":24,"items":25,"primary":26,"id":40,"slice_type":41,"slice_label":6},"sktwi1xtmkfgx8626",[],{"headline":27,"cta":33,"links":39},[28],{"type":29,"text":30,"spans":31,"direction":32},"heading1","Stake NIM and get {{ interestPerAnnum }} annually ",[],"ltr",{"link_type":34,"key":35,"url":36,"target":37,"text":38},"Web","11dfca11-af31-4672-b405-bb0d05e32aca","https://wallet.nimiq.com","_blank","Start staking",[],"hero_section$362ef66f-736c-4369-b46c-da08f3317cba","hero_section",{"variation":43,"version":44,"items":45,"primary":46,"id":59,"slice_type":60,"slice_label":6},"default","initial",[],{"quote":47,"cta":56},[48],{"type":49,"text":50,"spans":51,"direction":32},"paragraph","‘Staking’ means locking up NIM to help secure the network. Get new NIM as a reward. Unstake your NIM at any time.",[52],{"start":53,"end":54,"type":55},1,8,"strong",{"link_type":57,"key":58},"Any","57bd6f89-97d5-4a12-ab61-ef7deb35571e","quote$dc2a470b-78e8-4ca7-a383-6ed3e7317d74","quote",{"variation":43,"version":24,"items":62,"primary":63,"id":78,"slice_type":79,"slice_label":6},[],{"bgColor":64,"label":6,"headline":65,"subline":70,"cta":74,"linkHref":75,"linkLabel":6,"icon":76,"iconName":6,"backgroundColor":64,"links":77},"grey",[66],{"type":67,"text":68,"spans":69,"direction":32},"heading2","Check your potential staking rewards",[],[71],{"type":49,"text":72,"spans":73,"direction":32},"Play around with the staking calculator and find out how much NIM you could earn.",[],{"link_type":57},{"link_type":57},{},[],"simple_headline$589a173c-5899-471c-b54d-bbbf807b3277","simple_headline",{"variation":43,"version":44,"items":81,"primary":82,"id":109,"slice_type":110,"slice_label":6},[],{"title":83,"stakingAmountLabel":84,"initialStakingAmount":85,"stakedSupplyLabel":86,"stakedSupplyInfo":87,"stakingPeriodLabel":97,"stakingPeriodInfo":98,"autoRestakeLabel":102,"stakingRewardsLabel":103,"autoRestakeInfo":104,"note":108},"Staking calculator","Staking amount",1000000,"Staked supply",[88,91,94],{"type":49,"text":89,"spans":90,"direction":32},"This shows the percentage of all coins currently staked compared to the total supply.",[],{"type":49,"text":92,"spans":93,"direction":32},"A low stake is around 25%, a medium stake is 50% and a high stake is 75%.",[],{"type":49,"text":95,"spans":96,"direction":32},"The actual stake ratio isn't fixed, as it depends on how many NIM owners choose to stake. If fewer people stake, your share of the global reward will increase.",[],"Staking period",[99],{"type":49,"text":100,"spans":101,"direction":32},"The staking period determines how long your funds are locked in. A longer period will generally result in a greater return on your investment.",[],"Auto restake","Staking rewards",[105],{"type":49,"text":106,"spans":107,"direction":32},"Stake pools allow you to automatically reinvest the rewards you earn, which can increase your total rewards over time through compounding.",[],"* depends on the current total staking","staking_calculator$654139b2-bec1-4faf-9db2-a91b9d37a635","staking_calculator",{"variation":43,"version":24,"items":112,"primary":113,"id":127,"slice_type":79,"slice_label":6},[],{"bgColor":19,"label":114,"headline":115,"subline":119,"cta":123,"linkHref":124,"linkLabel":6,"icon":125,"iconName":6,"backgroundColor":64,"links":126},"Staking Distribution",[116],{"type":67,"text":117,"spans":118,"direction":32},"Active and decentralized staking",[],[120],{"type":49,"text":121,"spans":122,"direction":32},"A healthy network has a high staked supply, evenly distributed among the various pools and validators.",[],{"link_type":57},{"link_type":57},{},[],"simple_headline$9cd3aec6-7a00-4e58-9167-454c4830d69f",{"variation":43,"version":44,"items":129,"primary":130,"id":146,"slice_type":147,"slice_label":6},[],{"marketCapDistributionInfo":131,"stakedDistributionInfo":139},[132,136],{"type":133,"text":134,"spans":135,"direction":32},"heading3","How much is staked",[],{"type":49,"text":137,"spans":138,"direction":32},"A high staked supply means a safer network but smaller rewards.",[],[140,143],{"type":133,"text":141,"spans":142,"direction":32},"How the stakes are distributed",[],{"type":49,"text":144,"spans":145,"direction":32},"The more evenly stakes are distributed, the stronger the decentralization.",[],"staking_distribution$8fc11326-323b-4e22-b151-2f82ef24cefe","staking_distribution",{"variation":43,"version":24,"items":149,"primary":150,"id":164,"slice_type":79,"slice_label":6},[],{"bgColor":19,"label":151,"headline":152,"subline":156,"cta":160,"linkHref":161,"linkLabel":6,"icon":162,"iconName":6,"backgroundColor":64,"links":163},"Staking in the wallet",[153],{"type":67,"text":154,"spans":155,"direction":32},"So easy, everyone can do it!",[],[157],{"type":49,"text":158,"spans":159,"direction":32},"No tech skills or staking knowledge needed, stake in just three clicks. All it takes is a Nimiq Wallet and as little as 1000 NIM.",[],{"link_type":57},{"link_type":57},{},[],"simple_headline$981456e5-d680-4205-8ad1-5d0e8ee5159f",{"variation":43,"version":44,"items":166,"primary":167,"id":194,"slice_type":195,"slice_label":6},[],{"title":168,"subline":169,"backgroundImage":170,"poster":179,"video":186},"You stay in control","When staking, you ‘delegate’ your NIM \u2028to a pool but they remain in your wallet. \u2028Unstake them at any time.",{"dimensions":171,"alt":6,"copyright":6,"url":174,"id":175,"edit":176},{"width":172,"height":173},1800,838,"https://images.prismic.io/nimiq/ZzpTPq8jQArT08s8_wallet-black-white.webp?auto=format,compress","ZzpTPq8jQArT08s8",{"x":177,"y":177,"zoom":53,"background":178},0,"transparent",{"dimensions":180,"alt":6,"copyright":6,"url":183,"id":184,"edit":185},{"width":181,"height":182},840,1128,"https://images.prismic.io/nimiq/ZzpazK8jQArT08uI_Frame48104392.webp?auto=format,compress","ZzpazK8jQArT08uI",{"x":177,"y":177,"zoom":53,"background":178},{"link_type":187,"key":188,"kind":189,"id":190,"url":191,"name":192,"size":193},"Media","a4ce2f6f-7fa6-4861-afa5-2785a7988f67","file","Z21BuJbqstJ981da","https://nimiq.cdn.prismic.io/nimiq/Z21BuJbqstJ981da_ScreenRecording2024-12-26174136.mp4","Staking-in-nimiq.mp4","22365393","vertical_video$95eee2d0-864a-46ff-a53e-1e91059a8c91","vertical_video",{"variation":43,"version":24,"items":197,"primary":198,"id":212,"slice_type":79,"slice_label":6},[],{"bgColor":19,"label":199,"headline":200,"subline":204,"cta":208,"linkHref":209,"linkLabel":6,"icon":210,"iconName":6,"backgroundColor":19,"links":211},"Validator pools",[201],{"type":67,"text":202,"spans":203,"direction":32},"Let others do the work",[],[205],{"type":49,"text":206,"spans":207,"direction":32},"Not a techy? Stake with a validator. They take care of all the work, earning a small fee. You are always in control of your NIM.",[],{"link_type":57},{"link_type":57},{},[],"simple_headline$b1321aaf-bb4e-4606-bc1a-4763a6ef1ff8",{"variation":43,"version":44,"items":214,"primary":215,"id":216,"slice_type":217,"slice_label":6},[],{},"validator_list$200af2a5-d362-4b96-a98a-6f33e077dd7e","validator_list",{"variation":5,"version":24,"items":219,"primary":220,"id":239,"slice_type":240,"slice_label":6},[],{"headline":221,"cta":225,"requirements":229},[222],{"type":67,"text":223,"spans":224,"direction":32},"Want to run a validator yourself? Check out the docs.",[],{"link_type":34,"key":226,"url":227,"target":37,"text":228},"e8e9bb1e-e9f1-4059-92fe-ed44cf737b74","https://www.nimiq.com/developers/build/set-up-your-own-node/becoming-a-validator","Become a validator",[230,233,236],{"icon":231,"description":232},"i-nimiq:code","Solid tech knowledge required",{"icon":234,"description":235},"i-nimiq:document-filled bottom--2","Comprehensive docs and guides",{"icon":237,"description":238},"i-nimiq:globe-filled","Active and helpful community","banner_slice$8ba2a381-362c-4494-b9f3-ae8fb69d3101","banner_slice",{"variation":43,"version":44,"items":242,"primary":243,"id":305,"slice_type":306,"slice_label":6},[],{"title":244,"questions":245,"cta":300,"moreInsightfulLabel":304},"What you nEed to know",[246,255,264,273,282,291],{"question":247,"answer":251},[248],{"type":133,"text":249,"spans":250,"direction":32},"What is Staking?",[],[252],{"type":49,"text":253,"spans":254,"direction":32},"Staking is the process of delegating tokens to a validator. The validator then uses these tokens to validate transactions and produce blocks on your behalf.",[],{"question":256,"answer":260},[257],{"type":133,"text":258,"spans":259,"direction":32},"What is a validator?",[],[261],{"type":49,"text":262,"spans":263,"direction":32},"A validator is the block producer of Proof-of-Stake blockchains, like a miner in Proof-of-Work blockchains. Validators produce blocks according to a consensus algorithm. ",[],{"question":265,"answer":269},[266],{"type":133,"text":267,"spans":268,"direction":32},"What is a staking pool?",[],[270],{"type":49,"text":271,"spans":272,"direction":32},"While a validator is an individual entity, a staking pool combines the tokens of multiple participants into a single large entity, increasing their collective stake and chances of winning rewards.",[],{"question":274,"answer":278},[275],{"type":133,"text":276,"spans":277,"direction":32},"How does staking help the Nimiq network?",[],[279],{"type":49,"text":280,"spans":281,"direction":32},"Staking helps keep the Nimiq network secure and decentralized. The more NIM is staked and distributed evenly across validators, the stronger and healthier the network becomes, ensuring its reliability.",[],{"question":283,"answer":287},[284],{"type":133,"text":285,"spans":286,"direction":32},"What happens if I don’t stake?",[],[288],{"type":49,"text":289,"spans":290,"direction":32},"You can choose not to stake and not earn any rewards. By not staking, you miss the opportunity to help maintain the network secure and decentralized.",[],{"question":292,"answer":296},[293],{"type":133,"text":294,"spans":295,"direction":32},"How long does it take to have my funds available after I un-stake?",[],[297],{"type":49,"text":298,"spans":299,"direction":32},"Once you un-stake your funds, it usually takes between 12 hours to 4 days for them to become available. The exact time frame depends on your validator's status. In rare cases, validators can be \"jailed\" for up to 4 days, which may delay access to your funds.",[],{"link_type":34,"key":301,"url":302,"target":37,"text":303},"5ba9f7b3-0427-4c4f-bbf4-ba6657935829","https://forum.nimiq.community/","Nimiq forum","Get more insightful answers at the Nimiq forum.","staking_faq$cb136088-daf3-4a69-bd3d-ad99e6e285e1","staking_faq",{"variation":43,"version":24,"items":308,"primary":309,"id":326,"slice_type":79,"slice_label":6},[],{"bgColor":64,"label":6,"headline":310,"subline":314,"cta":320,"linkHref":323,"linkLabel":6,"icon":324,"iconName":6,"backgroundColor":64,"links":325},[311],{"type":67,"text":312,"spans":313,"direction":32},"Stake in the Nimiq wallet and get {{ interestPerAnnum }} annually",[],[315],{"type":49,"text":316,"spans":317,"direction":32},"‘Staking’ means locking up your NIM which helps secure the network. You get new NIM as a reward.",[318],{"start":177,"end":319,"type":55},9,{"link_type":34,"key":321,"url":36,"target":37,"text":322},"54b9a1b1-51f3-4ef4-96e6-bd04fc58d06e","Create a wallet",{"link_type":57},{},[],"simple_headline$893d8f06-18ce-4f5d-8b7c-b906f570be91",{},{"appsGroupName":329,"appsLinks":330,"howToTitle":452,"howToLinks":453,"appsAdditionalFooterLinks":469,"techGroupName":470,"techLinks":471,"githubLinkLabel":517,"techAdditionalFooterLinks":518,"communityGroupName":519,"communityLinks":520,"communityAdditionalFooterLinks":561,"projectGroupName":562,"projectLinks":563,"projectAdditionalFooterLinks":602,"getStartedGroupName":603,"getStartedLinks":604,"newToCryptoTitle":6,"newToCryptoLinks":627,"getStartedAdditionalFooterLinks":628,"andMoreGroupName":629,"andMoreLinks":630,"legalPages":650,"extraHeaderLinks":651,"newsletterCta":652,"newsletterPlaceholder":653,"socialMediaCta":654,"nimiqShortDescription":655,"hothref":656,"hottext":664,"hotsince":665,"hotuntil":6,"announcementBannerHeadline":666,"announcementBannerCtaLabel":667,"announcementBannerCtaLink":668,"announcementBannerShow":18,"blocks":671,"copyrightNotice":788},"Apps",[331,360,386,406,428],{"logo":332,"visual":341,"label":350,"href":351},{"dimensions":333,"alt":335,"copyright":6,"url":336,"id":337,"edit":338},{"width":334,"height":334},48,"Nimiq Logo","https://nimiq.cdn.prismic.io/nimiq/0dbc2a74-5cfb-4b19-a734-611379f6a591_nimiq-product-icon.svg","YlWuhRIAAC0AZFYp",{"x":177,"y":177,"zoom":339,"background":340},2,"#fff",{"dimensions":342,"alt":345,"copyright":6,"url":346,"id":347,"edit":348},{"width":343,"height":344},594,384,"Screenshot of the Nimiq Wallet","https://images.prismic.io/nimiq/18669675-be09-47fd-99bf-5c6eb8e091c0_header-wallet-hero.jpg?auto=compress,format&rect=0,0,817,528&w=594&h=384","ZPXRPBEAACEAS93s",{"x":177,"y":177,"zoom":349,"background":340},0.7272727272727273,"Wallet",{"id":352,"type":7,"tags":353,"lang":15,"slug":354,"first_pu