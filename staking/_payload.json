[{"data":1,"prerenderedAt":867},["ShallowReactive",2],{"prismic-page-staking":3,"$prismic_navigation":330,"staking_values":791,"$socialMedias":794},{"id":4,"uid":5,"url":6,"type":7,"href":8,"tags":9,"first_publication_date":10,"last_publication_date":11,"slugs":12,"linked_documents":14,"lang":15,"alternate_languages":16,"data":17},"ZzM2ihAAACMAh138","staking",null,"page","https://nimiq.cdn.prismic.io/api/v2/documents/search?ref=aCQychIAACAAohjp&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22ZzM2ihAAACMAh138%22%29+%5D%5D",[],"2024-11-12T12:40:47+0000","2024-12-26T11:47:09+0000",[13],"stake-nim-and-get--interestperannum--annually",[],"en-us",[],{"draft":18,"headerBackgroundColor":19,"footerBackgroundColor":19,"show_table_of_contents":20,"show_disclaimer":18,"darkHeader":18,"parents":21,"slices":22,"meta_title":6,"meta_description":6,"meta_keywords":6,"meta_image":329},false,"white","None",[],[23,42,62,82,113,130,150,167,198,215,220,243,309],{"variation":5,"version":24,"items":25,"primary":26,"id":40,"slice_type":41,"slice_label":6},"sktwi1xtmkfgx8626",[],{"headline":27,"cta":33,"links":39},[28],{"type":29,"text":30,"spans":31,"direction":32},"heading1","Stake NIM and get {{ interestPerAnnum }} annually ",[],"ltr",{"link_type":34,"key":35,"url":36,"target":37,"text":38},"Web","11dfca11-af31-4672-b405-bb0d05e32aca","https://wallet.nimiq.com","_blank","Start staking",[],"hero_section$362ef66f-736c-4369-b46c-da08f3317cba","hero_section",{"variation":43,"version":44,"items":45,"primary":46,"id":60,"slice_type":61,"slice_label":6},"default","initial",[],{"quote":47,"cta":56},[48],{"type":49,"text":50,"spans":51,"direction":32},"paragraph","‘Staking’ means locking up NIM to help secure the network. Get new NIM as a reward. Unstake your NIM at any time.",[52],{"start":53,"end":54,"type":55},1,8,"strong",{"link_type":34,"key":57,"url":58,"target":37,"text":59},"57bd6f89-97d5-4a12-ab61-ef7deb35571e","https://nimiq.com","Learn more","quote$dc2a470b-78e8-4ca7-a383-6ed3e7317d74","quote",{"variation":43,"version":24,"items":63,"primary":64,"id":80,"slice_type":81,"slice_label":6},[],{"bgColor":65,"label":6,"headline":66,"subline":71,"cta":75,"linkHref":77,"linkLabel":6,"icon":78,"iconName":6,"backgroundColor":65,"links":79},"grey",[67],{"type":68,"text":69,"spans":70,"direction":32},"heading2","Check your potential staking rewards",[],[72],{"type":49,"text":73,"spans":74,"direction":32},"Play around with the staking calculator and find out how much NIM you could earn.",[],{"link_type":76},"Any",{"link_type":76},{},[],"simple_headline$589a173c-5899-471c-b54d-bbbf807b3277","simple_headline",{"variation":43,"version":44,"items":83,"primary":84,"id":111,"slice_type":112,"slice_label":6},[],{"title":85,"stakingAmountLabel":86,"initialStakingAmount":87,"stakedSupplyLabel":88,"stakedSupplyInfo":89,"stakingPeriodLabel":99,"stakingPeriodInfo":100,"autoRestakeLabel":104,"stakingRewardsLabel":105,"autoRestakeInfo":106,"note":110},"Staking calculator","Staking amount",1000000,"Staked supply",[90,93,96],{"type":49,"text":91,"spans":92,"direction":32},"This shows the percentage of all coins currently staked compared to the total supply.",[],{"type":49,"text":94,"spans":95,"direction":32},"A low stake is around 25%, a medium stake is 50% and a high stake is 75%.",[],{"type":49,"text":97,"spans":98,"direction":32},"The actual stake ratio isn't fixed, as it depends on how many NIM owners choose to stake. If fewer people stake, your share of the global reward will increase.",[],"Staking period",[101],{"type":49,"text":102,"spans":103,"direction":32},"The staking period determines how long your funds are locked in. A longer period will generally result in a greater return on your investment.",[],"Auto restake","Staking rewards",[107],{"type":49,"text":108,"spans":109,"direction":32},"Stake pools allow you to automatically reinvest the rewards you earn, which can increase your total rewards over time through compounding.",[],"* depends on the current total staking","staking_calculator$654139b2-bec1-4faf-9db2-a91b9d37a635","staking_calculator",{"variation":43,"version":24,"items":114,"primary":115,"id":129,"slice_type":81,"slice_label":6},[],{"bgColor":19,"label":116,"headline":117,"subline":121,"cta":125,"linkHref":126,"linkLabel":6,"icon":127,"iconName":6,"backgroundColor":65,"links":128},"Staking Distribution",[118],{"type":68,"text":119,"spans":120,"direction":32},"Active and decentralized staking",[],[122],{"type":49,"text":123,"spans":124,"direction":32},"A healthy network has a high staked supply, evenly distributed among the various pools and validators.",[],{"link_type":76},{"link_type":76},{},[],"simple_headline$9cd3aec6-7a00-4e58-9167-454c4830d69f",{"variation":43,"version":44,"items":131,"primary":132,"id":148,"slice_type":149,"slice_label":6},[],{"marketCapDistributionInfo":133,"stakedDistributionInfo":141},[134,138],{"type":135,"text":136,"spans":137,"direction":32},"heading3","How much is staked",[],{"type":49,"text":139,"spans":140,"direction":32},"A high staked supply means a safer network but smaller rewards.",[],[142,145],{"type":135,"text":143,"spans":144,"direction":32},"How the stakes are distributed",[],{"type":49,"text":146,"spans":147,"direction":32},"The more evenly stakes are distributed, the stronger the decentralization.",[],"staking_distribution$8fc11326-323b-4e22-b151-2f82ef24cefe","staking_distribution",{"variation":43,"version":24,"items":151,"primary":152,"id":166,"slice_type":81,"slice_label":6},[],{"bgColor":19,"label":153,"headline":154,"subline":158,"cta":162,"linkHref":163,"linkLabel":6,"icon":164,"iconName":6,"backgroundColor":65,"links":165},"Staking in the wallet",[155],{"type":68,"text":156,"spans":157,"direction":32},"So easy, everyone can do it!",[],[159],{"type":49,"text":160,"spans":161,"direction":32},"No tech skills or staking knowledge needed, stake in just three clicks. All it takes is a Nimiq Wallet and as little as 1000 NIM.",[],{"link_type":76},{"link_type":76},{},[],"simple_headline$981456e5-d680-4205-8ad1-5d0e8ee5159f",{"variation":43,"version":44,"items":168,"primary":169,"id":196,"slice_type":197,"slice_label":6},[],{"title":170,"subline":171,"backgroundImage":172,"poster":181,"video":188},"You stay in control","When staking, you ‘delegate’ your NIM \u2028to a pool but they remain in your wallet. \u2028Unstake them at any time.",{"dimensions":173,"alt":6,"copyright":6,"url":176,"id":177,"edit":178},{"width":174,"height":175},1800,838,"https://images.prismic.io/nimiq/ZzpTPq8jQArT08s8_wallet-black-white.webp?auto=format,compress","ZzpTPq8jQArT08s8",{"x":179,"y":179,"zoom":53,"background":180},0,"transparent",{"dimensions":182,"alt":6,"copyright":6,"url":185,"id":186,"edit":187},{"width":183,"height":184},840,1128,"https://images.prismic.io/nimiq/ZzpazK8jQArT08uI_Frame48104392.webp?auto=format,compress","ZzpazK8jQArT08uI",{"x":179,"y":179,"zoom":53,"background":180},{"link_type":189,"key":190,"kind":191,"id":192,"url":193,"name":194,"size":195},"Media","a4ce2f6f-7fa6-4861-afa5-2785a7988f67","file","Z21BuJbqstJ981da","https://nimiq.cdn.prismic.io/nimiq/Z21BuJbqstJ981da_ScreenRecording2024-12-26174136.mp4","Staking-in-nimiq.mp4","22365393","vertical_video$95eee2d0-864a-46ff-a53e-1e91059a8c91","vertical_video",{"variation":43,"version":24,"items":199,"primary":200,"id":214,"slice_type":81,"slice_label":6},[],{"bgColor":19,"label":201,"headline":202,"subline":206,"cta":210,"linkHref":211,"linkLabel":6,"icon":212,"iconName":6,"backgroundColor":19,"links":213},"Validator pools",[203],{"type":68,"text":204,"spans":205,"direction":32},"Let others do the work",[],[207],{"type":49,"text":208,"spans":209,"direction":32},"Not a techy? Stake with a validator. They take care of all the work, earning a small fee. You are always in control of your NIM.",[],{"link_type":76},{"link_type":76},{},[],"simple_headline$b1321aaf-bb4e-4606-bc1a-4763a6ef1ff8",{"variation":43,"version":44,"items":216,"primary":217,"id":218,"slice_type":219,"slice_label":6},[],{},"validator_list$200af2a5-d362-4b96-a98a-6f33e077dd7e","validator_list",{"variation":5,"version":24,"items":221,"primary":222,"id":241,"slice_type":242,"slice_label":6},[],{"headline":223,"cta":227,"requirements":231},[224],{"type":68,"text":225,"spans":226,"direction":32},"Want to run a validator yourself? Check out the docs.",[],{"link_type":34,"key":228,"url":229,"target":37,"text":230},"e8e9bb1e-e9f1-4059-92fe-ed44cf737b74","https://www.nimiq.com/developers/build/set-up-your-own-node/becoming-a-validator","Become a validator",[232,235,238],{"icon":233,"description":234},"i-nimiq:code","Solid tech knowledge required",{"icon":236,"description":237},"i-nimiq:document-filled bottom--2","Comprehensive docs and guides",{"icon":239,"description":240},"i-nimiq:globe-filled","Active and helpful community","banner_slice$8ba2a381-362c-4494-b9f3-ae8fb69d3101","banner_slice",{"variation":43,"version":44,"items":244,"primary":245,"id":307,"slice_type":308,"slice_label":6},[],{"title":246,"questions":247,"cta":302,"moreInsightfulLabel":306},"What you nEed to know",[248,257,266,275,284,293],{"question":249,"answer":253},[250],{"type":135,"text":251,"spans":252,"direction":32},"What is Staking?",[],[254],{"type":49,"text":255,"spans":256,"direction":32},"Staking is the process of delegating tokens to a validator. The validator then uses these tokens to validate transactions and produce blocks on your behalf.",[],{"question":258,"answer":262},[259],{"type":135,"text":260,"spans":261,"direction":32},"What is a validator?",[],[263],{"type":49,"text":264,"spans":265,"direction":32},"A validator is the block producer of Proof-of-Stake blockchains, like a miner in Proof-of-Work blockchains. Validators produce blocks according to a consensus algorithm. ",[],{"question":267,"answer":271},[268],{"type":135,"text":269,"spans":270,"direction":32},"What is a staking pool?",[],[272],{"type":49,"text":273,"spans":274,"direction":32},"While a validator is an individual entity, a staking pool combines the tokens of multiple participants into a single large entity, increasing their collective stake and chances of winning rewards.",[],{"question":276,"answer":280},[277],{"type":135,"text":278,"spans":279,"direction":32},"How does staking help the Nimiq network?",[],[281],{"type":49,"text":282,"spans":283,"direction":32},"Staking helps keep the Nimiq network secure and decentralized. The more NIM is staked and distributed evenly across validators, the stronger and healthier the network becomes, ensuring its reliability.",[],{"question":285,"answer":289},[286],{"type":135,"text":287,"spans":288,"direction":32},"What happens if I don’t stake?",[],[290],{"type":49,"text":291,"spans":292,"direction":32},"You can choose not to stake and not earn any rewards. By not staking, you miss the opportunity to help maintain the network secure and decentralized.",[],{"question":294,"answer":298},[295],{"type":135,"text":296,"spans":297,"direction":32},"How long does it take to have my funds available after I un-stake?",[],[299],{"type":49,"text":300,"spans":301,"direction":32},"Once you un-stake your funds, it usually takes between 12 hours to 4 days for them to become available. The exact time frame depends on your validator's status. In rare cases, validators can be \"jailed\" for up to 4 days, which may delay access to your funds.",[],{"link_type":34,"key":303,"url":304,"target":37,"text":305},"5ba9f7b3-0427-4c4f-bbf4-ba6657935829","https://forum.nimiq.community/","Nimiq forum","Get more insightful answers at the Nimiq forum.","staking_faq$cb136088-daf3-4a69-bd3d-ad99e6e285e1","staking_faq",{"variation":43,"version":24,"items":310,"primary":311,"id":328,"slice_type":81,"slice_label":6},[],{"bgColor":65,"label":6,"headline":312,"subline":316,"cta":322,"linkHref":325,"linkLabel":6,"icon":326,"iconName":6,"backgroundColor":65,"links":327},[313],{"type":68,"text":314,"spans":315,"direction":32},"Stake in the Nimiq wallet and get {{ interestPerAnnum }} annually",[],[317],{"type":49,"text":318,"spans":319,"direction":32},"‘Staking’ means locking up your NIM which helps secure the network. You get new NIM as a reward.",[320],{"start":179,"end":321,"type":55},9,{"link_type":34,"key":323,"url":36,"target":37,"text":324},"54b9a1b1-51f3-4ef4-96e6-bd04fc58d06e","Create a wallet",{"link_type":76},{},[],"simple_headline$893d8f06-18ce-4f5d-8b7c-b906f570be91",{},{"appsGroupName":331,"appsLinks":332,"howToTitle":454,"howToLinks":455,"appsAdditionalFooterLinks":471,"techGroupName":472,"techLinks":473,"githubLinkLabel":519,"techAdditionalFooterLinks":520,"communityGroupName":521,"communityLinks":522,"communityAdditionalFooterLinks":563,"projectGroupName":564,"projectLinks":565,"projectAdditionalFooterLinks":604,"getStartedGroupName":605,"getStartedLinks":606,"newToCryptoTitle":6,"newToCryptoLinks":629,"getStartedAdditionalFooterLinks":630,"andMoreGroupName":631,"andMoreLinks":632,"legalPages":652,"extraHeaderLinks":653,"newsletterCta":654,"newsletterPlaceholder":655,"socialMediaCta":656,"nimiqShortDescription":657,"hothref":658,"hottext":666,"hotsince":667,"hotuntil":6,"announcementBannerHeadline":668,"announcementBannerCtaLabel":669,"announcementBannerCtaLink":670,"announcementBannerShow":18,"blocks":673,"copyrightNotice":790},"Apps",[333,362,388,408,430],{"logo":334,"visual":343,"label":352,"href":353},{"dimensions":335,"alt":337,"copyright":6,"url":338,"id":339,"edit":340},{"width":336,"height":336},48,"Nimiq Logo","https://nimiq.cdn.prismic.io/nimiq/0dbc2a74-5cfb-4b19-a734-611379f6a591_nimiq-product-icon.svg","YlWuhRIAAC0AZFYp",{"x":179,"y":179,"zoom":341,"background":342},2,"#fff",{"dimensions":344,"alt":347,"copyright":6,"url":348,"id":349,"edit":350},{"width":345,"height":346},594,384,"Screenshot of the Nimiq Wallet","https://images.prismic.io/nimiq/18669675-be09-47fd-99bf-5c6eb8e091c0_header-wallet-hero.jpg?auto=compress,format&rect=0,0,817,528&w=594&h=384","ZPXRPBEAACEAS93s",{"x":179,"y":179,"zoom":351,"background":342},0.7272727272727273,"Wa