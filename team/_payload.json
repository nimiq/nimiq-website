[{"data":1,"prerenderedAt":949},["ShallowReactive",2],{"prismic-page-team":3,"$prismic_navigation":418,"staking_values":873,"$socialMedias":876},{"id":4,"uid":5,"url":6,"type":7,"href":8,"tags":9,"first_publication_date":10,"last_publication_date":11,"slugs":12,"linked_documents":14,"lang":15,"alternate_languages":16,"data":17},"YjORTRIAAC0AJM4x","team",null,"page","https://nimiq.cdn.prismic.io/api/v2/documents/search?ref=aIdnnxAAACcA_UJ9&q=%5B%5B%3Ad+%3D+at%28document.id%2C+%22YjORTRIAAC0AJM4x%22%29+%5D%5D",[],"2022-03-17T19:55:43+0000","2024-09-24T11:45:33+0000",[13],"the-team",[],"en-us",[],{"draft":18,"headerBackgroundColor":19,"footerBackgroundColor":19,"show_table_of_contents":20,"show_disclaimer":18,"darkHeader":6,"parents":21,"slices":22,"meta_title":6,"meta_description":6,"meta_keywords":6,"meta_image":417},false,"white","None",[],[23,54,393],{"variation":24,"version":25,"items":26,"primary":28,"id":52,"slice_type":53,"slice_label":6},"default-slice","sktwi1xtmkfgx8626",[27],{"highlight":6},{"backgroundColor":19,"label":6,"headline":29,"subline":34,"linkHref":39,"linkLabel":6,"link":41,"secondaryLinkHref":42,"secondaryLinkLabel":6,"secondaryLink":43,"videoHref":44,"videoLabel":6,"note":45,"lottieAnimation":46,"playStore":48,"appStore":49,"bgColor":19,"video":50,"links":51},[30],{"type":31,"text":32,"spans":33},"heading1","The Team",[],[35],{"type":36,"text":37,"spans":38},"paragraph","Team Nimiq is driven to contribute something to society that is meaningful, large scale and cutting edge. Join us.",[],{"link_type":40},"Any",{"link_type":40},{"link_type":40},{"link_type":40},{"link_type":40},[],{"link_type":47},"Media",{"link_type":40},{"link_type":40},{"link_type":40},[],"hero_section$0befe31e-ce53-4a8b-b6d1-a405692ab199","hero_section",{"variation":55,"version":25,"items":56,"primary":390,"id":391,"slice_type":392,"slice_label":6},"default",[57,76,88,100,113,126,138,153,167,181,194,206,218,231,245,257,270,284,297,309,323,338,352,366,381],{"picture":58,"fullName":69,"role":70,"description":71,"linkedin":6,"github":75,"twitter":6},{"dimensions":59,"alt":6,"copyright":6,"url":62,"id":63,"edit":64},{"width":60,"height":61},690,510,"https://images.prismic.io/nimiq/ec1f8794-f353-4bfa-8d79-e144fa3a1958_team_1826.4026019867163_5d64c9eb9926bc4db83026c2.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbotBIAAC4AaeE2",{"x":65,"y":66,"zoom":67,"background":68},0,-18,2.15625,"transparent","Marvin Wissfeld","Blockchain Core & Systems Developer",[72],{"type":36,"text":73,"spans":74},"Presenter at 2017 IEEE Symposium on Security & Privacy in Silicon Valley. At age 14 earned first pocket money through his webpage. One of the youngest mentors at Google Summer of Code, Expert on Malware Analysis, Mobile and Web Security. Personal passion for Privacy Engineering, all matters Android and Cryptography.",[],"test",{"picture":77,"fullName":82,"role":83,"description":84,"linkedin":6,"github":6,"twitter":6},{"dimensions":78,"alt":6,"copyright":6,"url":79,"id":80,"edit":81},{"width":60,"height":61},"https://images.prismic.io/nimiq/eba1386a-910c-4625-b434-30cdda80c55e_team_3764.6470657772493_5d64c9eb9926bc4db83026c2+%281%29.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlboTxIAAC8Aad9a",{"x":65,"y":66,"zoom":67,"background":68},"Tammo Mamedi","UI/UX & Communication",[85],{"type":36,"text":86,"spans":87},"Co-owner ‘overnice’ branding and digital communication agency. Built experience and portfolio at Jung von Matt. Consulted the German Foreign Ministry on digital matters. Food entrepreneur. Personal passion for communication strategies and helping early stage ventures get it right.",[],{"picture":89,"fullName":94,"role":95,"description":96,"linkedin":6,"github":6,"twitter":6},{"dimensions":90,"alt":6,"copyright":6,"url":91,"id":92,"edit":93},{"width":60,"height":61},"https://images.prismic.io/nimiq/32ff1c3b-c246-4a91-9929-a8e035545bc6_team_6204.447170902298_5d64c9eb9926bc4db83026c2.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlboxBIAACsAaeF_",{"x":65,"y":66,"zoom":67,"background":68},"Julian Bauer","Design",[97],{"type":36,"text":98,"spans":99},"Co-owner ‘overnice’ branding and digital communication agency. Consulted the German Foreign Ministry on digital matters. Established a delivery platform for Subway Germany. Frontend developed the Skype Bot Developers Platform. Strong passion for both the big picture as well as attention to detail in UI and UX implementation.",[],{"picture":101,"fullName":106,"role":107,"description":108,"linkedin":112,"github":6,"twitter":6},{"dimensions":102,"alt":6,"copyright":6,"url":103,"id":104,"edit":105},{"width":60,"height":61},"https://images.prismic.io/nimiq/31247d65-f4a4-4cc9-8df8-c6f475f998e6_team_491.33471371867853_5d08d98ab99e6d07dc3245ba+%282%29.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbozhIAACwAaeG1",{"x":65,"y":66,"zoom":67,"background":68},"Pascal Berrang","Blockchain Researcher & Core Developer",[109],{"type":36,"text":110,"spans":111},"Assistant Professor for Cyber Security at the University of Birmingham, UK. PhD (s.c.l.) in Computer Science (focus on Security & Privacy) at SU with over a dozen publications in top-tier venues of the field and several scholarships. Former member of saarsec CTF team scoring 3rd at RuCTFE 2015, 2nd at iCTF 2015 and 2nd at RuCTF 2016.",[],"paberr",{"picture":114,"fullName":119,"role":120,"description":121,"linkedin":6,"github":6,"twitter":6},{"dimensions":115,"alt":6,"copyright":6,"url":116,"id":117,"edit":118},{"width":60,"height":61},"https://images.prismic.io/nimiq/e0c9c2b7-700b-413c-9b82-b79317e35a27_team_3163.507250344202_5d64c9eb9926bc4db83026c2.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpDxIAACwAaeLO",{"x":65,"y":66,"zoom":67,"background":68},"Jeffrey Esquivel","Blockchain Core Developer",[122],{"type":36,"text":123,"spans":124,"direction":125},"Jeffrey founded and sold a software development company after which he joined HPE's Networking Research and Development Center as a Systems Engineer. He holds a bachelor's degree in Electric Engineering from University of Costa Rica.",[],"ltr",{"picture":127,"fullName":132,"role":133,"description":134,"linkedin":6,"github":6,"twitter":6},{"dimensions":128,"alt":6,"copyright":6,"url":129,"id":130,"edit":131},{"width":60,"height":61},"https://images.prismic.io/nimiq/8a564743-d38b-41a9-8aef-47689f6f5fa0_team_8637_369.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpHBIAACgAaeMS",{"x":65,"y":66,"zoom":67,"background":68},"Mauricio Lara","Counsel & Representation",[135],{"type":36,"text":136,"spans":137},"Mauricio is a Costa Rican attorney and member of both the Costa Rican and American Bar Association. He is also a member of the Association of Certified Financial Crime Specialists (www.acfcs.org), a leading authority in compliance and financial regulation. He is a partner of InterTax, a legal and accounting services firm with offices in Weston, Brickell and Orlando, FL and San José, Costa Rica and has been advising crypto businesses since early 2014. Mauricio has been invited as speaker to multiple conferences regarding banking, digital payments, cryptocurrencies and regulation for crypto related businesses and compliance. His paper “The Last Decade of Cash” was presented at the Costa Rican International Information Technology Forum 2014. Mauricio is an avid surfer, a long-distance triathlete and cross country mountain biker. He is passionate about evangelizing governmental authorities on distributed ledger technology and applications for law and government and foresees public service in his future.",[],{"picture":139,"fullName":147,"role":148,"description":149,"linkedin":6,"github":6,"twitter":6},{"dimensions":140,"alt":6,"copyright":6,"url":141,"id":142,"edit":143},{"width":60,"height":61},"https://images.prismic.io/nimiq/622e655c-4594-44ed-961d-752cbb2832b6__DSC1029.jpg?auto=compress,format&rect=0,61,1176,869&w=690&h=510","YlbnVxIAAC4Aadrw",{"x":65,"y":144,"zoom":145,"background":146},-36,0.5867346938775511,"#fff","Ricardo Barquero","Communication Manager",[150],{"type":36,"text":151,"spans":152,"direction":125},"Telecom Engineer by profession. Cryptocurrency evangelist by choice. Responsible for running entire backbone infrastructure for largest Cable & Internet Provider in Costa Rica. Technical writer at leading WebRTC company TokBox.",[],{"picture":154,"fullName":159,"role":160,"description":161,"linkedin":165,"github":166,"twitter":6},{"dimensions":155,"alt":6,"copyright":6,"url":156,"id":157,"edit":158},{"width":60,"height":61},"https://images.prismic.io/nimiq/76c45190-25a1-4c93-ac7a-9c3eb8d320b5_team_8281.570345155715_5d08d98ab99e6d07dc3245ba+%281%29.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpKhIAACwAaeNR",{"x":65,"y":66,"zoom":67,"background":68},"Sören Schwert","Front-end Engineer",[162],{"type":36,"text":163,"spans":164},"Worked as requirements engineer and developed a keen eye for detail and perfectionism. As passionate Javascript coder, Nimiq's first Hacker News post was his perfect excuse to dive head-first into blockchains and cryptocurrencies. Sören is an avid follower and active community member and created the first Nimiq blockchain explorer nimiq.watch. He now applies his problem-solving skills to user-interfaces and helps new developers get started in the Nimiq ecosystem.",[],"s%C3%B6ren-schwert-484b6b100","sisou",{"picture":168,"fullName":175,"role":120,"description":176,"linkedin":6,"github":180,"twitter":6},{"dimensions":169,"alt":6,"copyright":6,"url":170,"id":171,"edit":172},{"width":60,"height":61},"https://images.prismic.io/nimiq/983c5990-1a07-4442-9c6f-1990d8c8ae6c__DSC1013+2.jpg?auto=compress,format&rect=0,48,1114,823&w=690&h=510","YlbnmRIAACsAadwh",{"x":65,"y":173,"zoom":174,"background":146},-30,0.6193895870736086,"Claudio Viquez",[177],{"type":36,"text":178,"spans":179},"Claudio studied electrical engineering and mathematics at UCR. He led a team of embedded networking engineers during 5+ years at HP where he published 10+ patents in networking, distributed systems and algorithms. His interests cover formal systems, logic, philosophy and more recently, blockchain technologies and cryptography. He also holds a commercial pilot license and enjoys writing songs, producing and recording other artists, and playing in different venues with his band around Costa Rica.",[],"viquezclaudio",{"picture":182,"fullName":187,"role":188,"description":189,"linkedin":6,"github":193,"twitter":6},{"dimensions":183,"alt":6,"copyright":6,"url":184,"id":185,"edit":186},{"width":60,"height":61},"https://images.prismic.io/nimiq/fda2228e-51bb-4b7e-9c20-289d6e201535_team_8532.48357239435_5d08d98ab99e6d07dc3245ba.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpORIAAC8AaeOU",{"x":65,"y":66,"zoom":67,"background":68},"Philipp von Styp-Rekowsky","Nimiq Co-Creator, Blockchain Tech Lead",[190],{"type":36,"text":191,"spans":192},"PhD (s.c.l.) in Computer Science at SU with the Information Security and Cryptography Group at CISPA (Center for Cybersecurity, Privacy and Accountability).BSc at the German Research Center for Artificial Intelligence. MSc at Max Planck Institute for Computer Science. Built award-winning software AppGuard and Boxify. Published in several journals and technical reports. Personal passion for Blockchain technology and making security usable without compromising.",[],"styppo",{"picture":195,"fullName":200,"role":160,"description":201,"linkedin":6,"github":205,"twitter":6},{"dimensions":196,"alt":6,"copyright":6,"url":197,"id":198,"edit":199},{"width":60,"height":61},"https://images.prismic.io/nimiq/17436c53-20a8-412f-8a8d-19796d344412_team_7111.254405291021_5d08d98ab99e6d07dc3245ba.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpRRIAACwAaePM",{"x":65,"y":66,"zoom":67,"background":68},"Daniel Mohr",[202],{"type":36,"text":203,"spans":204},"Research assistant at German research center for AI working on intelligent User Interfaces. Computer Science Tutor and TA at SU. Passion for implementing progressive App responsive UIs and front-ends.",[],"danimoh",{"picture":207,"fullName":212,"role":213,"description":214,"linkedin":6,"github":6,"twitter":6},{"dimensions":208,"alt":6,"copyright":6,"url":209,"id":210,"edit":211},{"width":60,"height":61},"https://images.prismic.io/nimiq/d3fa0e8e-9ef0-45fb-82c9-6e88e80c4d07_team_5173_369.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpURIAAC8AaeQB",{"x":65,"y":66,"zoom":67,"background":68},"Curd Becker","System Virtuoso",[215],{"type":36,"text":216,"spans":217},"Curd is a hardware and network systems security expert at heart. He studied computer science at Saarland University, specializing early on in system administration and moving up to Head of Information Technology at CISPA (Center for Cybersecurity, Privacy and Accountability). At CISPA he managed heterogeneous hardware and software platforms across a mix of 70+ physical and virtual servers. Curd volunteered as \"Programming for Engineers\" tutor for refugees during the immigration wave that particularly challenged Germany. He has a personal passion for operating systems with a focus on security testing and reverse engineering. Several hardware security projects he worked on are strictly confidential.",[],{"picture":219,"fullName":224,"role":225,"description":226,"linkedin":6,"github":230,"twitter":6},{"dimensions":220,"alt":6,"copyright":6,"url":221,"id":222,"edit":223},{"width":60,"height":61},"https://images.prismic.io/nimiq/04cb4ee1-d017-47b9-91d8-09d33cae28ee_team_8562.244135672072_5d08d98ab99e6d07dc3245ba+%281%29.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpXxIAACkAaeRC",{"x":65,"y":66,"zoom":67,"background":68},"Sebastian Dietel","Front-end Engineer & Core Developer",[227],{"type":36,"text":228,"spans":229},"Sebastian read his first book about programming at the age of 13 and not much later launched his first proper website. Driven by the question ‘What else can I make this machine do?’ he studied Computer Science at SU. He worked as a full stack web developer for almost a decade and delivered a number of award nominated sites for MA-X new media agency. Sebastian loves to challenge himself to learning new things and has a personal passion for implementing uncluttered and intuitive interfaces.",[],"nibhar",{"picture":232,"fullName":239,"role":120,"description":240,"linkedin":6,"github":244,"twitter":6},{"dimensions":233,"alt":6,"copyright":6,"url":234,"id":235,"edit":236},{"width":60,"height":61},"https://images.prismic.io/nimiq/3e36f103-7b23-4c9e-8c9e-47437b60a63b__DSC1017.jpg?auto=compress,format&rect=0,47,1056,781&w=690&h=510","YlbnwxIAACkAadzd",{"x":65,"y":237,"zoom":238,"background":146},-31,0.6534090909090909,"Jose Hernandez",[241],{"type":36,"text":242,"spans":243},"JD studied Electrical Engineering at UCR and has a Computer Science Master’s from Georgia Institute of Technology.He also worked as an associate professor at UCR for Electrical Engineering undergraduate courses.Along with Claudio he led a team of embedded system engineers in charge of writing abstraction APIs for networking ASICs for the wired division of HPE Aruba. His interests cover open source software, system design & architecture, artificial intelligence and blockchain.",[],"jsdanielh",{"picture":246,"fullName":251,"role":160,"description":252,"linkedin":256,"github":6,"twitter":6},{"dimensions":247,"alt":6,"copyright":6,"url":248,"id":249,"edit":250},{"width":60,"height":61},"https://images.prismic.io/nimiq/33d3e7f6-ab09-441d-ae41-d59fa5b64184_team_187165_b30.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpgBIAACgAaeTi",{"x":65,"y":66,"zoom":67,"background":68},"Mathéo Raveux",[253],{"type":36,"text":254,"spans":255},"So passionate about web development that he left school to go straight into freelancing. Driven by his thirst for learning and innovating as well as his taste for quality code, he became the technical director of French communication agency Adelios before the age of 20. Mathéo was instrumental to helping the agency win several distinctions on websites like Awwwards, cssdesignawards and FWA. Now a member of the Nimiq team, he continues to pursue his goal of creating ever more innovative tools, aimed at an ever more demanding audience.",[],"math%C3%A9o-r-b301a996",{"picture":258,"fullName":263,"role":264,"description":265,"linkedin":269,"github":6,"twitter":6},{"dimensions":259,"alt":6,"copyright":6,"url":260,"id":261,"edit":262},{"width":60,"height":61},"https://images.prismic.io/nimiq/066b49e4-08de-4603-b3b4-e3a22944a2ca_team_3576.4563458062094_5d08d98ab99e6d07dc3245ba.png?auto=compress,format&rect=0,8,320,237&w=690&h=510","YlbpixIAAC4AaeUT",{"x":65,"y":66,"zoom":67,"background":68},"Elion Chin","Nimiq Co-Creator, Operations",[266],{"type":36,"text":267,"spans":268},"Cofounder, Investor and CFO of Silicon Valley based MoodLogic Inc. sold 2006 to AMG (now publicly listed ROVI). PhD (s.c.l) in Economics at Swiss University of St. Gallen and visiting PhD at Stern School of Business, NYU. Built the Silicon Paradise Tech movement in Costa Rica and SkyLoft as secluded incubation base for ideas and early stage startups. Collaboration with Carao Ventures on vetting and supporting startups and professional efforts with high social and ecological impact.",[],"elionchin",{"picture":271,"fullName":278,"role":279,"description":280,"linkedin":6,"github":6,"twitter":6},{"dimensions":272,"alt":6,"copyright":6,"url":273,"id":274,"edit":275},{"width":60,"height":61},"https://images.prismic.io/nimiq/249c7c8b-fe15-4a78-bc64-7cc99bd94e94_Bild+von+iOS.jpg?auto=compress,format&rect=0,24,1193,882&w=690&h=510","YlfIZxIAAC4AbcIH",{"x":65,"y":276,"zoom":277,"background":146},-14,0.5783738474434199,"Michael Passias","Community Manager",[281],{"type":36,"text":282,"spans":283},"As a certified sales professional and trainer with a passion for crypto and economics, Micha loves to spark excitement in any potential future Nimiq holder; so basically everyone! Former external business development representative and project manager of teams working on behalf of companies like SAP SE (EMEA) and Acronis Germany GmbH (DACH). You have an idea to enrich the Nimiq ecosystem with your project? Get in touch and he’ll be happy to make it become reality with the NIMcubator.",[],{"picture":285,"fullName":291,"role":292,"description":293,"linkedin":6,"github":6,"twitter":6},{"dimensions":286,"alt":6,"copyright":6,"url":287,"id":288,"edit":289},{"width":60,"height":61},"https://images.prismic.io/nimiq/ee994b65-67cf-41b3-b720-106962e015d0__DSC1033.jpg?auto=compress,format&rect=0,53,1182,874&w=690&h=510","YlfIzBIAACkAbcPM",{"x":65,"y":237,"zoom":290,"background":146},0.583756345177665,"Roberto Cruz","Store Onboarding Manager",[294],{"type":36,"text":295,"spans":296},"Roberto is a Physics major with background studies in Economics. He was part of academic research teams at University of Costa Rica in subjects ranging from nuclear energy to solid-state physics. Always wondering how else to apply his skills, he transitioned into Communication with the idea of bridging technical concepts to non-technical people. Firm believer in accessible resources for everyone alike.",[],{"picture":298,"fullName":304,"role":120,"description":305,"linkedin":6,"github":6,"twitter":6},{"dimensions":299,"alt":6,"copyright":6,"url":300,"id":301,"edit":302},{"width":60,"height":61},"https://images.prismic.io/nimiq/ee65b25f-6090-46fc-a8b4-21dbe310a50b_linkedin+pic+1+%281%29.jpg?auto=compress,format&rect=0,0,4154,3070&w=690&h=510","YxzPLBAAACQAmex5",{"x":65,"y":65,"zoom":303,"background":146},0.16610495907558978,"Inês Cruz",[306],{"type":36,"text":307,"spans":308},"Inês has a Computer Science Master Degree from the NOVA University of Lisbon, where she focused on decentralized systems and computations. She is the recipient of a scholarship grant for the MIT Blockchain Disruptive Technology program. She volunteered on the Board of European Students of Technology as International VP, overseeing 90+ European local groups, and as supervisor and mentor of 15+ academic courses for STEM students.",[],{"picture":310,"fullName":317,"role":318,"description":319,"linkedin":6,"github":6,"twitter":6},{"dimensions":311,"alt":6,"copyright":6,"url":312,"id":313,"edit":314},{"width":60,"height":61},"https://images.prismic.io/nimiq/0d4aada3-9c9b-4a4c-b6c6-eb2c5ad3855f_ines-marques+1.jpg?auto=compress,format&rect=186,0,3464,2560&w=690&h=510","Yx7cWBAAACQAotxp",{"x":315,"y":65,"zoom":316,"background":146},-37,0.19921875,"Inês Marques","Technical Writer",[320],{"type":36,"text":321,"spans":322},"Ines has loved to write for as long as she can remember, and it has been her life's hobby of choice. After attending a front-end development course, she shifted her specialization towards technical writing and joined the team. Working with Nimiq combines two of her life goals: simplifying people's lives and writing.",[],{"picture":324,"fullName":331,"role":332,"description":333,"linkedin":337,"github":6,"twitter":6},{"dimensions":325,"alt":6,"copyright":6,"url":326,"id":327,"edit":328},{"width":60,"height":61},"https://images.prismic.io/nimiq/4168443c-fc56-441b-a1e5-495a35724795_martin_desouza.jpg?auto=compress,format&rect=0,8,1400,1035&w=690&h=510","Y9ecShEAACUAsG2r",{"x":65,"y":329,"zoom":330,"background":146},-4,0.4928571428571429,"Martin DeSouza","Ecosystem Development",[334],{"type":36,"text":335,"spans":336},"Martin DeSouza is a business development professional with a proven track record of success in leadership, communication and entrepreneurship. He has an intense focus on moving projects forward and has experience working in the Canadian Innovation ecosystem including mentoring and connecting entrepreneurs with angel investors and venture capitalists. He has a passion for small business and is inspired by the potential for blockchain to revolutionize the way entrepreneurs run their businesses. Martin is known for his networking, management, and problem-solving abilities.",[],"desouzamartin",{"picture":339,"fullName":346,"role":160,"description":347,"linkedin":6,"github":351,"twitter":6},{"dimensions":340,"alt":6,"copyright":6,"url":341,"id":342,"edit":343},{"width":60,"height":61},"https://images.prismic.io/nimiq/f0b20128-48a2-4c09-ade8-782849267403_1106-890-max.jpg?auto=compress,format&rect=0,37,1106,817&w=690&h=510","Y9hg8xEAACUAs8YB",{"x":65,"y":344,"zoom":345,"background":146},-23,0.6238698010849909,"Maximo García",[348],{"type":36,"text":349,"spans":350},"Max studied Computer Engineering at UPM. He has been always passionate about programming in general: from building a neuronal networks to write bots and scripts. And after trying many things, the thing he enjoys the most is web development. The youngest in the team and very eager to learn about anything.",[],"onmax",{"picture":353,"fullName":359,"role":332,"description":360,"linkedin":364,"github":6,"twitter":365},{"dimensions":354,"alt":6,"copyright":6,"url":355,"id":356,"edit":357},{"width":60,"height":61},"https://images.prismic.io/nimiq/2185ae65-fe67-4bee-8d95-cb5f67c45303_22-03-13+Max+Burger.png?auto=compress,format&rect=0,17,640,473&w=690&h=510","Ylht8BIAACwAcLTd",{"x":65,"y":66,"zoom":358,"background":68},1.078125,"Max Burger",[361],{"type":36,"text":362,"spans":363},"Max joins Nimiq from a Director position at MCI, one of the worlds leading experience marketing agencies. With an MBA from the Technical University of Chemnitz, an early background as maker entrepreneur and astronomy as a passion, he is also a fitting nerd at heart. Max has taken to the stage and been a guest lecturer on various occasions including the Bavarian Academy for Business Communication and his Alma Mater. If there’s a complicated task, Max won’t stop until he finds a way to achieve the goal. He is excited about taking on the crypto mass adoption challenge and finding creative marketing and ecosystem development ways of connecting the nerd pieces with everyday comfort levels!",[],"maxvburger","Max_Nimiq",{"picture":367,"fullName":374,"role":225,"description":375,"linkedin":379,"github":380,"twitter":6},{"dimensions":368,"alt":6,"copyright":6,"url":369,"id":370,"edit":371},{"width":60,"height":61},"https://images.prismic.io/nimiq/cc849f5f-5e96-470e-b9ca-13818bd1798c_Rectangle+354+%281%29.png?auto=compress,format&rect=0,522,4000,2957&w=690&h=510","ZHhwjhAAACkAnHif",{"x":65,"y":372,"zoom":373,"background":68},-90,0.1725,"Stefan Koolen",[376],{"type":36,"text":377,"spans":378},"Stefan holds a Computer Science degree at Rotterdam University and was a former tech lead at a software startup focusing on data synchronization. As long as he can remember he has been fascinated by technology. Since joining the Nimiq community back in 2017 he has contributed to various projects. He has a passion for making complex architectures pleasant to use. Apart from technology he enjoys traveling and wants to see as much of the world as possible.",[],"stefan-koolen","Eligioo",{"picture":382,"fullName":383,"role":384,"description":385,"linkedin":389,"github":6,"twitter":6},{},"Adrián García","Advisor LatAm Regulators & Fintech Bridge",[386],{"type":36,"text":387,"spans":388,"direction":125},"Adrián is a Costa Rican entrepreneur, co-founder of Carao Ventures and Terraba, pioneering companies in the fields of venture capital and e-commerce. He has advised and invested in emerging companies for the past 15 years, and taught and mentored entrepreneurs at leading universities such as MIT, Stanford and INCAE. As a board member, he has supported various innovative companies and non-profits that work for social progress. He holds a BA in Economics with Honors from the University of Texas at Austin and and MBA from the MIT School of Management and is part of the Aspen Global Leadership Network.",[],"adriangarcia81",{"backgroundColor":19},"team_members$3d858024-77e4-4677-aa9f-9deabffc4c40","team_members",{"variation":55,"version":25,"i